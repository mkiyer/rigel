"""
hulkrna.counter - Read count accumulation with EM.

ReadCounter accumulates read counts into transcript arrays.

For uniquely-mapping fragments, assignment is deterministic.  For ambiguous
fragments, transcript abundances are estimated via standard EM with a
uniform Dirichlet prior, then counts are accumulated from the converged
posterior.

Posterior expected-count assignment
----------------------------------
After EM convergence, ambiguous RNA units are accumulated as expected
counts from the RNA-normalized posterior distribution rather than by
stochastic winner sampling.  This removes Monte-Carlo noise and greatly
reduces transcript dropout/over-allocation artifacts on heavily
ambiguous loci, while preserving probabilistic attribution.

EM algorithm
------------
Standard EM with effective-length normalization and a uniform
Dirichlet prior (α₀ = pseudocount, default 0.5).

1. Initialize θ from unique counts + prior α₀.
2. E-step: posterior ∝ likelihood × θ_t / ℓ_eff_t.
3. M-step: θ_t ∝ α₀ + unique_t + Σ_f P(t | f).
4. Repeat until convergence (relative delta < 1e-6).
5. Assign: add posterior-expected counts per ambiguous unit.
"""

import logging
from dataclasses import dataclass, field

import numpy as np
import pandas as pd

from .types import Strand
from .categories import (
    ANTISENSE_COLS,
    SpliceType,
    SpliceStrandCol,
    NUM_SPLICE_STRAND_COLS,
    SPLICED_COLS,
)

logger = logging.getLogger(__name__)

# Epsilon added to theta before taking log to prevent log(0) in EM.
_EM_LOG_EPSILON = 1e-300

# Relative convergence tolerance for EM theta updates.
_EM_CONVERGENCE_DELTA = 1e-6


# ======================================================================
# EMData - pre-computed CSR arrays for vectorized EM
# ======================================================================


@dataclass(slots=True)
class EMData:
    """Pre-computed CSR arrays for vectorized EM.

    Attributes
    ----------
    offsets : np.ndarray
        int64[n_units + 1] - CSR offsets into flat arrays.
    t_indices : np.ndarray
        int32[n_candidates] - candidate transcript or shadow indices.
    log_liks : np.ndarray
        float64[n_candidates] - log(P_strand x P_insert) per candidate.
    count_cols : np.ndarray
        uint8[n_candidates] - internal column index per candidate (0-7).
    locus_t_indices : np.ndarray
        int32[n_units] - best transcript index per unit.
    locus_count_cols : np.ndarray
        uint8[n_units] - count column for the locus transcript.
    n_units : int
        Number of ambiguous units.
    n_candidates : int
        Total number of (unit, candidate) entries.
    nrna_base_index : int
        First nRNA shadow index (= num_transcripts).
    gdna_exonic_base_index : int
        First gDNA shadow index (= 2 * num_transcripts).
    """

    offsets: np.ndarray
    t_indices: np.ndarray
    log_liks: np.ndarray
    count_cols: np.ndarray
    locus_t_indices: np.ndarray
    locus_count_cols: np.ndarray
    n_units: int
    n_candidates: int
    nrna_base_index: int
    gdna_exonic_base_index: int


# ======================================================================
# Locus — connected component of transcripts linked by shared fragments
# ======================================================================


@dataclass(slots=True)
class Locus:
    """A connected component of transcripts linked by shared fragments.

    Transcripts in a locus are connected through fragment compatibility:
    if fragment F maps to transcripts {A, C} and fragment G maps to {C, D},
    then A, C, D are in the same locus.

    Attributes
    ----------
    locus_id : int
        Sequential label (0-based).
    transcript_indices : np.ndarray
        int32 — global transcript indices in this locus.
    gene_indices : np.ndarray
        int32 — global gene indices in this locus.
    unit_indices : np.ndarray
        int32 — EM unit indices (rows in global CSR) belonging to this locus.
    gdna_intervals : list[tuple[str, int, int]]
        Merged genomic intervals ``(ref, start, end)`` for the gDNA shadow.
        Built from transcript extents of all transcripts in the locus.
    gdna_footprint_bp : int
        Sum of interval sizes = gDNA effective length.
    gdna_init_count : float
        Unspliced fragment count initializing the gDNA shadow
        (strand-corrected antisense aggregated across the locus).
    """

    locus_id: int
    transcript_indices: np.ndarray
    gene_indices: np.ndarray
    unit_indices: np.ndarray
    gdna_intervals: list = field(default_factory=list)
    gdna_footprint_bp: int = 0
    gdna_init_count: float = 0.0


# ======================================================================
# LocusEMData — per-locus EM sub-problem with local component indices
# ======================================================================


@dataclass(slots=True)
class LocusEMData:
    """Per-locus EM sub-problem with locally-renumbered component indices.

    Component layout::

        [0, n_t)           — mRNA (one per transcript in the locus)
        [n_t, 2*n_t)       — nRNA (one per transcript, nascent shadow)
        [2*n_t, 2*n_t+n_g) — gDNA (one per gene in the locus)

    Total components = ``2 * n_transcripts + n_genes``.

    Attributes
    ----------
    locus : Locus
        The parent locus.
    offsets : np.ndarray
        int64[n_local_units + 1] — CSR row pointers.
    t_indices : np.ndarray
        int32[n_local_candidates] — LOCAL component indices.
    log_liks : np.ndarray
        float64[n_local_candidates] — log-likelihoods.
    count_cols : np.ndarray
        uint8[n_local_candidates] — column indices for count accumulation.
    locus_t_indices : np.ndarray
        int32[n_local_units] — best transcript index per unit (global).
    locus_count_cols : np.ndarray
        uint8[n_local_units] — count column for the best transcript.
    n_transcripts : int
        Number of transcripts in the locus.
    n_genes : int
        Number of genes in the locus.
    n_components : int
        ``2 * n_transcripts + n_genes`` (mRNA + nRNA + per-gene gDNA).
    local_to_global_t : np.ndarray
        int32[n_transcripts] — maps local transcript index → global.
    local_to_global_g : np.ndarray
        int32[n_genes] — maps local gene index → global.
    unique_totals : np.ndarray
        float64[n_components] — init counts (unique + shadow inits).
    nrna_init : np.ndarray
        float64[n_transcripts] — per-transcript nRNA init.
    gdna_init : float
        Scalar gDNA init for this locus.
    effective_lengths : np.ndarray
        float64[n_components] — effective lengths for EM normalization.
    prior : np.ndarray
        float64[n_components] — Dirichlet prior pseudocounts.
    gdna_intervals : list
        Genomic intervals ``(ref, start, end)`` for gDNA reporting.
    """

    locus: Locus
    offsets: np.ndarray
    t_indices: np.ndarray
    log_liks: np.ndarray
    count_cols: np.ndarray
    locus_t_indices: np.ndarray
    locus_count_cols: np.ndarray
    n_transcripts: int
    n_genes: int
    n_components: int
    local_to_global_t: np.ndarray
    local_to_global_g: np.ndarray
    unique_totals: np.ndarray
    nrna_init: np.ndarray
    gdna_init: np.ndarray
    effective_lengths: np.ndarray
    prior: np.ndarray
    gdna_intervals: list = field(default_factory=list)


# ======================================================================
# ReadCounter
# ======================================================================


class ReadCounter:
    """Accumulates read counts into transcript arrays.

    Count arrays have shape (N, NUM_SPLICE_STRAND_COLS) where columns correspond
    to 3 categories × 2 strands (sense/antisense).

    Three-pool EM architecture::

        [0, N_t)                         — mRNA transcript components
        [N_t, 2*N_t)                     — nRNA shadow per transcript
        [2*N_t, 2*N_t + 2*N_g)          — gDNA shadow per gene

    Fragment routing:

    - SPLICED_ANNOT + unique → deterministic mRNA (no shadow competition)
    - All other → transcript candidates + nRNA + gDNA shadows

    Uses standard EM with effective length normalization and a uniform
    Dirichlet prior for robust abundance estimation.

    Parameters
    ----------
    num_transcripts : int
    num_genes : int
    seed : int or None
    alpha : float
        Dirichlet prior pseudocount (default 0.01).
    """

    def __init__(
        self,
        num_transcripts: int,
        num_genes: int,
        *,
        seed=None,
        alpha: float = 0.01,
        effective_lengths: np.ndarray | None = None,
        t_to_g: np.ndarray | None = None,
        gene_spans: np.ndarray | None = None,
        mean_frag: float = 200.0,
        intronic_spans: np.ndarray | None = None,
        transcript_spans: np.ndarray | None = None,
    ):
        self.num_transcripts = num_transcripts
        self.num_genes = num_genes
        self.em_prior = alpha
        self._rng = np.random.default_rng(seed)

        # Three-pool base indices for EM theta vector.
        # nRNA shadows occupy [N_t, 2*N_t) — one per transcript.
        # gDNA shadows remain per gene: [2*N_t, 2*N_t + 2*N_g).
        self.nrna_base_index = num_transcripts
        self.gdna_exonic_base_index = 2 * num_transcripts
        self._n_em_components = 2 * num_transcripts + 2 * num_genes

        # Transcript → gene index mapping
        self._t_to_g = (
            np.asarray(t_to_g, dtype=np.int32) if t_to_g is not None
            else None
        )

        # Per-gene genomic spans (end − start)
        self._gene_spans = (
            np.asarray(gene_spans, dtype=np.float64)
            if gene_spans is not None
            else None
        )
        self._mean_frag = float(mean_frag)

        # Per-gene intronic spans (gene_span - merged_exonic_length)
        self._intronic_spans = (
            np.asarray(intronic_spans, dtype=np.float64)
            if intronic_spans is not None
            else None
        )

        # Per-transcript genomic spans (end - start, unspliced pre-mRNA length)
        self._transcript_spans = (
            np.asarray(transcript_spans, dtype=np.float64)
            if transcript_spans is not None
            else None
        )

        # --- Effective lengths for EM normalization ---
        if effective_lengths is not None:
            self._t_eff_len = np.maximum(
                np.asarray(effective_lengths, dtype=np.float64), 1.0
            )
        else:
            self._t_eff_len = np.ones(
                num_transcripts, dtype=np.float64
            )

        self.unique_counts = np.zeros(
            (num_transcripts, NUM_SPLICE_STRAND_COLS), dtype=np.float64
        )
        self.em_counts = np.zeros(
            (num_transcripts, NUM_SPLICE_STRAND_COLS), dtype=np.float64
        )

        # Per-transcript high-confidence EM counts (posterior >= threshold).
        self.em_high_conf_counts = np.zeros(
            (num_transcripts, NUM_SPLICE_STRAND_COLS), dtype=np.float64
        )

        # Per-transcript nRNA shadow initialization and EM counts.
        # nRNA is a transcript-level phenomenon: one nascent RNA shadow
        # per transcript isoform, indexed at nrna_base_index + t_idx.
        self.nrna_init = np.zeros(num_transcripts, dtype=np.float64)
        self.nrna_em_counts = np.zeros(num_transcripts, dtype=np.float64)

        # Per-gene gDNA shadow initialization and EM counts (split).
        self.gdna_exonic_init = np.zeros(num_genes, dtype=np.float64)
        self.gdna_intronic_init = np.zeros(num_genes, dtype=np.float64)
        self.gdna_em_counts = np.zeros(num_genes, dtype=np.float64)
        self.gdna_exonic_em_counts = np.zeros(num_genes, dtype=np.float64)
        self.gdna_intronic_em_counts = np.zeros(num_genes, dtype=np.float64)

        # Per-transcript locus attribution of gDNA assignments.
        self.gdna_locus_counts = np.zeros(
            (num_transcripts, NUM_SPLICE_STRAND_COLS), dtype=np.float64
        )

        # --- Pre-EM strand accumulators (for gDNA init) ---
        # Gene-level: all single-gene fragments (FRAG_UNIQUE +
        # FRAG_ISOFORM_AMBIG), any splice type.
        # Used by _compute_gdna_init (strand-corrected antisense).
        self.gene_sense_all = np.zeros(num_genes, dtype=np.float64)
        self.gene_antisense_all = np.zeros(num_genes, dtype=np.float64)

        # --- Pre-EM intronic accumulators (for nRNA init) ---
        # Transcript-level: nRNA is per-transcript.  Each transcript
        # has its own intron structure; intron_bp[k] > 0 means this
        # fragment overlaps an intron of transcript k specifically.
        self.transcript_intronic_sense = np.zeros(
            num_transcripts, dtype=np.float64
        )
        self.transcript_intronic_antisense = np.zeros(
            num_transcripts, dtype=np.float64
        )

        # Converged transcript abundance from EM (set by run_em)
        self._converged_theta: np.ndarray | None = None
        self._converged_alpha: np.ndarray | None = None

        # Per-transcript confidence tracking:
        # _em_posterior_sum[t] = sum of posteriors at which t was chosen
        # _em_n_assigned[t] = effective number of assigned units to t
        self._em_posterior_sum: np.ndarray | None = None
        self._em_n_assigned: np.ndarray | None = None

    @property
    def effective_lengths(self) -> np.ndarray:
        """Per-transcript effective lengths (read-only)."""
        return self._t_eff_len

    def _build_eff_len_vector(self) -> np.ndarray:
        """Build full effective-length vector for EM (transcripts + 2 shadows).

        Layout: [transcripts | nRNA | gDNA]

        - **Transcript** [0, N_t): ``Σ(exon_lengths) − f̄ + 1``
          (standard RNA-seq formula).
        - **nRNA** [N_t, 2*N_t): ``max(transcript_span − f̄ + 1, 1)``
          — nascent RNA covers the full unspliced transcript span.
          One shadow per transcript isoform.
        - **gDNA** [2*N_t, 2*N_t+2*N_g): ``max(gene_span − f̄ + 1, 1)``
          — one shadow per gene; overlap likelihood (not eff len)
          controls the discrimination between gDNA and RNA.
        """
        n_total = self._n_em_components
        eff_len = np.ones(n_total, dtype=np.float64)
        nt = self.num_transcripts
        ng = self.num_genes
        eff_len[:nt] = self._t_eff_len

        # nRNA: per-transcript unspliced span eff length
        if self._transcript_spans is not None:
            t_nrna_eff = np.maximum(
                self._transcript_spans - self._mean_frag + 1.0, 1.0
            )
            eff_len[self.nrna_base_index:
                    self.nrna_base_index + nt] = t_nrna_eff
        elif self._gene_spans is not None and self._t_to_g is not None:
            # Fallback: use gene span mapped to each transcript
            gene_eff = np.maximum(
                self._gene_spans - self._mean_frag + 1.0, 1.0
            )
            eff_len[self.nrna_base_index:
                    self.nrna_base_index + nt] = gene_eff[self._t_to_g]

        # gDNA: per-gene span eff length
        if self._gene_spans is not None:
            gene_eff = np.maximum(
                self._gene_spans - self._mean_frag + 1.0, 1.0
            )
            eff_len[self.gdna_exonic_base_index:
                    self.gdna_exonic_base_index + ng] = gene_eff

        return eff_len

    @property
    def gdna_unique_count(self) -> float:
        """Total gDNA shadow initialization (empirical Bayes prior)."""
        return float(
            self.gdna_exonic_init.sum() + self.gdna_intronic_init.sum()
        )

    @property
    def gdna_em_count(self) -> float:
        """Total EM-assigned gDNA count.

        When locus-level EM is used, this returns the locus-level
        total instead of the per-gene sum.
        """
        locus_total = getattr(self, '_locus_gdna_em_total', None)
        if locus_total is not None:
            return float(locus_total)
        return float(self.gdna_em_counts.sum())

    @property
    def nrna_em_count(self) -> float:
        """Total EM-assigned nRNA count."""
        return float(self.nrna_em_counts.sum())

    @property
    def gdna_total(self) -> float:
        """Total gDNA count (shadow_init + EM-assigned)."""
        return self.gdna_unique_count + self.gdna_em_count

    @property
    def gdna_contamination_rate(self) -> float:
        """Fraction of all fragments attributed to gDNA."""
        total_rna = float(self.unique_counts.sum() + self.em_counts.sum())
        total = total_rna + self.gdna_total
        if total == 0:
            return 0.0
        return self.gdna_total / total

    @property
    def t_counts(self) -> np.ndarray:
        """Total transcript counts (unique + EM), shape (N_t, 8)."""
        return self.unique_counts + self.em_counts

    @property
    def t_high_conf_counts(self) -> np.ndarray:
        """High-confidence transcript counts (unique + EM above threshold).

        Unique counts are always high-confidence.  EM counts are
        included only when the RNA-normalized posterior of the winner
        met or exceeded ``confidence_threshold`` during assignment.
        """
        return self.unique_counts + self.em_high_conf_counts

    # ------------------------------------------------------------------
    # Strand classification (internal)
    # ------------------------------------------------------------------

    @staticmethod
    def is_antisense(
        exon_strand,
        gene_strand: int,
        strand_model,
    ) -> bool:
        """Classify whether a fragment is antisense using the trained model.

        Uses the strand model decision boundary (p < 0.5).

        Returns
        -------
        bool
            True if antisense (p < 0.5), False if sense (p >= 0.5).
        """
        p = strand_model.strand_likelihood(exon_strand, Strand(gene_strand))
        return p < 0.5

    # ------------------------------------------------------------------
    # Unique assignment
    # ------------------------------------------------------------------

    def assign_unique(self, resolved, index, strand_models) -> None:
        """Deterministic assignment for a truly unique fragment."""
        t_inds = resolved.t_inds

        if len(t_inds) == 0:
            return

        t_idx = int(next(iter(t_inds)))
        g_idx = int(index.t_to_g_arr[t_idx])
        gene_strand = int(index.g_to_strand_arr[g_idx])
        sm = strand_models.model_for_category(resolved.splice_type)
        anti = self.is_antisense(resolved.exon_strand, gene_strand, sm)
        col = SpliceStrandCol.from_category(resolved.splice_type, anti)
        self.unique_counts[t_idx, col] += 1.0

    # ------------------------------------------------------------------
    # EM iteration (vectorized)
    # ------------------------------------------------------------------

    def run_em(self, em_data: EMData, *, em_iterations: int = 10) -> None:
        """Run standard EM with uniform Dirichlet prior (three-pool).

        EM vector layout: [transcripts | nRNA per transcript | gDNA per gene]

        1. Initialize θ from unique counts + shadow inits + prior.
        2. E-step: posterior ∝ L(f|t) × θ_t / ℓ_eff_t.
        3. M-step: θ ∝ unique + em_totals + prior.
        4. Repeat until convergence (relative delta < 1e-6).
        """
        n_total = self._n_em_components
        ng = self.num_genes
        nt = self.num_transcripts

        # Uniform Dirichlet prior for all components
        prior = np.full(n_total, self.em_prior, dtype=np.float64)

        # Zero-out gDNA prior when strand-corrected init is zero.
        # When there is no antisense evidence for gDNA at a gene, the
        # EM should not allocate mass to the gDNA shadow — especially
        # for single-exon genes where mRNA has no SPLICED_ANNOT anchor
        # and all fragments are UNSPLICED (entering the EM).
        for i in range(ng):
            if self.gdna_exonic_init[i] == 0.0:
                prior[self.gdna_exonic_base_index + i] = 0.0

        # Zero-out nRNA prior for single-exon transcripts.
        # nRNA is indistinguishable from mRNA for transcripts with no
        # introns — the pre-mRNA and mRNA sequences are identical.
        # We detect single-exon transcripts by comparing the
        # unspliced transcript span to its effective length:
        # transcript_span ≈ exonic_length when there are no introns.
        for i in range(nt):
            if self._transcript_spans is not None:
                # Approximate raw exonic length from effective length
                t_exon_approx = self._t_eff_len[i] + self._mean_frag - 1.0
                if self._transcript_spans[i] <= t_exon_approx:
                    prior[self.nrna_base_index + i] = 0.0
            elif (self._intronic_spans is not None
                  and self._t_to_g is not None):
                # Fallback: gene-level intronic span check
                g_idx = int(self._t_to_g[i])
                if self._intronic_spans[g_idx] <= 0:
                    prior[self.nrna_base_index + i] = 0.0

        # Initialize from unique counts + shadow inits
        unique_totals = np.zeros(n_total, dtype=np.float64)
        unique_totals[:nt] = self.unique_counts.sum(axis=1)
        unique_totals[self.nrna_base_index:
                      self.nrna_base_index + nt] = self.nrna_init
        unique_totals[self.gdna_exonic_base_index:
                      self.gdna_exonic_base_index + ng] = self.gdna_exonic_init

        if em_data.n_units == 0 or em_data.n_candidates == 0:
            alpha = unique_totals + prior
            self._converged_alpha = alpha
            self._converged_theta = alpha / alpha.sum()
            return

        offsets = em_data.offsets
        t_indices = em_data.t_indices
        log_liks = em_data.log_liks
        seg_lengths = np.diff(offsets)

        # Pre-compute log effective lengths for E-step normalization
        eff_len = self._build_eff_len_vector()
        log_eff_len = np.log(eff_len)

        # Balanced initialization: floor transcript components at
        # average shadow weight to prevent shadow-heavy local optima.
        theta_init = unique_totals.copy()
        if ng > 0 and nt > 0:
            all_shadow_weights = np.concatenate([
                theta_init[self.nrna_base_index:
                           self.nrna_base_index + nt],
                theta_init[self.gdna_exonic_base_index:
                           self.gdna_exonic_base_index + ng],
            ])
            avg_shadow = float(all_shadow_weights.mean())
            if avg_shadow > 0 and self._t_to_g is not None:
                floor = avg_shadow
                low = theta_init[:nt] < floor
                theta_init[:nt][low] = floor

        theta = (theta_init + prior)
        theta /= theta.sum()

        em_totals = np.zeros(n_total, dtype=np.float64)
        n_iters = 0
        for it in range(em_iterations):
            # E-step
            log_weights = np.log(theta + _EM_LOG_EPSILON) - log_eff_len
            log_posteriors = log_liks + log_weights[t_indices]

            # Segment-wise log-sum-exp normalization
            seg_max = np.maximum.reduceat(log_posteriors, offsets[:-1])
            log_posteriors -= np.repeat(seg_max, seg_lengths)
            posteriors = np.exp(log_posteriors)
            seg_sum = np.add.reduceat(posteriors, offsets[:-1])
            posteriors /= np.repeat(seg_sum, seg_lengths)

            # M-step
            em_totals = np.zeros(n_total, dtype=np.float64)
            np.add.at(em_totals, t_indices, posteriors)

            theta_new = unique_totals + em_totals + prior
            theta_new /= theta_new.sum()

            delta = np.abs(theta_new - theta).sum()
            theta = theta_new
            n_iters += 1

            logger.debug(f"  EM iteration {n_iters}: delta={delta:.6f}")

            if delta < _EM_CONVERGENCE_DELTA:
                logger.debug(
                    f"  EM converged after {n_iters} iterations"
                )
                break

        logger.debug(f"  EM total iterations: {n_iters}")

        alpha = unique_totals + em_totals + prior
        self._converged_alpha = alpha
        self._converged_theta = theta

        nrna_sum = alpha[self.nrna_base_index:
                         self.nrna_base_index + nt].sum()
        gdna_sum = alpha[self.gdna_exonic_base_index:
                         self.gdna_exonic_base_index + ng].sum()
        logger.info(
            f"  Three-pool EM alpha sums: nRNA={nrna_sum:.1f}, "
            f"gDNA={gdna_sum:.1f} / "
            f"unique={unique_totals.sum():.0f}"
        )

    # ------------------------------------------------------------------
    # Posterior expected-count assignment
    # ------------------------------------------------------------------

    def assign_ambiguous(
        self,
        em_data: EMData,
        *,
        gdna_threshold: float = 0.5,
        confidence_threshold: float = 0.95,
    ) -> None:
        """Assign ambiguous units via thresholded posterior expected counts.

        Three-pool classification per EM unit:

        - If sum(RNA posteriors) ≥ threshold → assign to mRNA/nRNA
          transcripts; else → gDNA shadow.

        Component classification by index range:
        - ``< nrna_base`` → mRNA transcript
        - ``∈ [nrna_base, gdna_exonic_base)`` → nRNA
        - ``≥ gdna_exonic_base`` → gDNA

        Must be called after ``run_em()``.

        Parameters
        ----------
        gdna_threshold : float
            Minimum sum of RNA posteriors (mRNA or nRNA) to classify
            as RNA.  0.0 → never assign to gDNA.
        confidence_threshold : float
            Minimum RNA-normalized posterior for high-confidence.
        """
        if em_data.n_units == 0 or em_data.n_candidates == 0:
            return

        alpha = self._converged_alpha
        if alpha is None:
            raise RuntimeError(
                "run_em() must be called before assign_ambiguous()"
            )

        offsets = em_data.offsets
        t_indices = em_data.t_indices
        log_liks = em_data.log_liks
        count_cols_arr = em_data.count_cols
        seg_lengths = np.diff(offsets)

        # Compute final posteriors using converged theta
        eff_len = self._build_eff_len_vector()
        log_weights = np.log(self._converged_theta + _EM_LOG_EPSILON) - np.log(eff_len)
        log_posteriors = log_liks + log_weights[t_indices]

        # Segment-wise softmax normalization
        seg_max = np.maximum.reduceat(log_posteriors, offsets[:-1])
        log_posteriors -= np.repeat(seg_max, seg_lengths)
        posteriors = np.exp(log_posteriors)
        seg_sum = np.add.reduceat(posteriors, offsets[:-1])
        posteriors /= np.repeat(seg_sum, seg_lengths)

        nrna_base = self.nrna_base_index
        gdna_base = self.gdna_exonic_base_index
        n_units = em_data.n_units

        for u in range(n_units):
            s, e = int(offsets[u]), int(offsets[u + 1])
            p = posteriors[s:e]
            t_seg = t_indices[s:e]

            # Classify each candidate by component type
            is_mrna = t_seg < nrna_base
            is_nrna = (t_seg >= nrna_base) & (t_seg < gdna_base)
            is_gdna = t_seg >= gdna_base

            # RNA = mRNA + nRNA candidates
            rna_mask = is_mrna | is_nrna
            p_rna = p[rna_mask]
            p_rna_total = float(p_rna.sum())

            has_shadow = is_gdna.any()

            if p_rna_total >= gdna_threshold or not has_shadow:
                # --- Assign to RNA (mRNA or nRNA) ---
                # mRNA transcript candidates
                mrna_local = np.where(is_mrna)[0]
                if len(mrna_local) > 0:
                    p_mrna = p[mrna_local]
                    p_mrna_total = float(p_mrna.sum())
                    if p_mrna_total > 0:
                        mrna_norm = p_mrna / max(p_rna_total, 1e-300)
                        mrna_idx = s + mrna_local
                        mrna_t = t_indices[mrna_idx]
                        mrna_col = count_cols_arr[mrna_idx]
                        np.add.at(
                            self.em_counts,
                            (mrna_t, mrna_col),
                            mrna_norm,
                        )
                        max_conf = float(mrna_norm.max())
                        if max_conf >= confidence_threshold:
                            np.add.at(
                                self.em_high_conf_counts,
                                (mrna_t, mrna_col),
                                mrna_norm,
                            )
                        # Confidence tracking
                        if self._em_posterior_sum is None:
                            self._em_posterior_sum = np.zeros(
                                self.num_transcripts, dtype=np.float64
                            )
                            self._em_n_assigned = np.zeros(
                                self.num_transcripts, dtype=np.float64
                            )
                        np.add.at(
                            self._em_posterior_sum,
                            mrna_t, mrna_norm * mrna_norm,
                        )
                        np.add.at(self._em_n_assigned, mrna_t, mrna_norm)

                # nRNA candidates (transcript-level)
                nrna_local = np.where(is_nrna)[0]
                if len(nrna_local) > 0:
                    p_nrna = p[nrna_local]
                    nrna_norm = p_nrna / max(p_rna_total, 1e-300)
                    nrna_idx = s + nrna_local
                    # nRNA shadow index = nrna_base + transcript_index
                    nrna_txs = t_indices[nrna_idx] - nrna_base
                    np.add.at(self.nrna_em_counts, nrna_txs, nrna_norm)

            else:
                # --- Assign to gDNA shadow ---
                gdna_local = np.where(is_gdna)[0]
                if len(gdna_local) > 0:
                    gdna_idx = s + gdna_local
                    gdna_genes = t_indices[gdna_idx] - gdna_base
                    p_gdna = p[gdna_local]
                    p_gdna_total = float(p_gdna.sum())
                    if p_gdna_total > 0:
                        gdna_norm = p_gdna / p_gdna_total
                    else:
                        gdna_norm = np.full(
                            len(gdna_local),
                            1.0 / len(gdna_local),
                            dtype=np.float64,
                        )
                    np.add.at(
                        self.gdna_exonic_em_counts,
                        gdna_genes, gdna_norm,
                    )
                    np.add.at(
                        self.gdna_em_counts,
                        gdna_genes, gdna_norm,
                    )

                # Locus attribution
                locus_t = em_data.locus_t_indices[u]
                locus_ct = em_data.locus_count_cols[u]
                if locus_t >= 0:
                    self.gdna_locus_counts[locus_t, locus_ct] += 1.0

    # ------------------------------------------------------------------
    # Per-locus EM (locus-level decomposition)
    # ------------------------------------------------------------------

    def run_locus_em(
        self,
        locus_em: LocusEMData,
        *,
        em_iterations: int = 1000,
    ) -> tuple[np.ndarray, np.ndarray]:
        """Run EM for a single locus sub-problem.

        Identical algorithm to ``run_em`` but operates on local
        component vectors (``2*n_t + 1`` components instead of the
        full global vector).

        Parameters
        ----------
        locus_em : LocusEMData
            Per-locus EM arrays with locally-renumbered indices.
        em_iterations : int
            Maximum EM iterations (default 1000).

        Returns
        -------
        tuple[np.ndarray, np.ndarray]
            ``(theta, alpha)`` — converged parameters for this locus.
        """
        n_total = locus_em.n_components
        prior = locus_em.prior.copy()
        unique_totals = locus_em.unique_totals.copy()

        offsets = locus_em.offsets
        t_indices = locus_em.t_indices
        log_liks = locus_em.log_liks

        n_units = len(offsets) - 1

        if n_units == 0 or len(t_indices) == 0:
            alpha = unique_totals + prior
            total = alpha.sum()
            theta = alpha / total if total > 0 else alpha
            return theta, alpha

        seg_lengths = np.diff(offsets)
        eff_len = locus_em.effective_lengths
        log_eff_len = np.log(eff_len)

        # Balanced initialization (mirror global EM logic)
        theta_init = unique_totals.copy()
        n_t = locus_em.n_transcripts
        n_g = locus_em.n_genes
        if n_t > 0:
            shadow_weights = np.concatenate([
                theta_init[n_t:2*n_t],              # nRNA
                theta_init[2*n_t:2*n_t + n_g],      # gDNA (per-gene)
            ])
            avg_shadow = float(shadow_weights.mean())
            if avg_shadow > 0:
                low = theta_init[:n_t] < avg_shadow
                theta_init[:n_t][low] = avg_shadow

        theta = theta_init + prior
        total = theta.sum()
        if total > 0:
            theta /= total

        em_totals = np.zeros(n_total, dtype=np.float64)
        n_iters = 0
        for _ in range(em_iterations):
            # E-step
            log_weights = np.log(theta + _EM_LOG_EPSILON) - log_eff_len
            log_posteriors = log_liks + log_weights[t_indices]

            seg_max = np.maximum.reduceat(log_posteriors, offsets[:-1])
            log_posteriors -= np.repeat(seg_max, seg_lengths)
            posteriors = np.exp(log_posteriors)
            seg_sum = np.add.reduceat(posteriors, offsets[:-1])
            posteriors /= np.repeat(seg_sum, seg_lengths)

            # M-step
            em_totals = np.zeros(n_total, dtype=np.float64)
            np.add.at(em_totals, t_indices, posteriors)

            theta_new = unique_totals + em_totals + prior
            total = theta_new.sum()
            if total > 0:
                theta_new /= total

            delta = np.abs(theta_new - theta).sum()
            theta = theta_new
            n_iters += 1

            if delta < _EM_CONVERGENCE_DELTA:
                break

        alpha = unique_totals + em_totals + prior
        return theta, alpha

    def assign_locus_ambiguous(
        self,
        locus_em: LocusEMData,
        theta: np.ndarray,
        *,
        gdna_threshold: float = 0.5,
        confidence_threshold: float = 0.95,
    ) -> float:
        """Assign ambiguous units within one locus, scattering to global arrays.

        Three-pool classification per unit:

        - RNA posterior sum ≥ ``gdna_threshold`` → distribute among
          mRNA/nRNA components.
        - Otherwise → gDNA.

        gDNA assignments are counted as a locus-level total (returned)
        and reported in genomic coordinates — NOT attributed to genes.

        Parameters
        ----------
        locus_em : LocusEMData
            Per-locus EM data with local component indices.
        theta : np.ndarray
            Converged theta from ``run_locus_em``.
        gdna_threshold : float
            Minimum RNA posterior sum to classify as RNA.
        confidence_threshold : float
            Minimum RNA-normalized posterior for high-confidence flag.

        Returns
        -------
        float
            Number of fragments assigned to gDNA in this locus.
        """
        offsets = locus_em.offsets
        t_indices = locus_em.t_indices
        log_liks = locus_em.log_liks
        count_cols_arr = locus_em.count_cols
        n_units = len(offsets) - 1

        if n_units == 0 or len(t_indices) == 0:
            return 0.0

        n_t = locus_em.n_transcripts
        n_g = locus_em.n_genes
        gdna_base = 2 * n_t  # gDNA components: [2*n_t, 2*n_t + n_g)
        local_to_global_t = locus_em.local_to_global_t
        local_to_global_g = locus_em.local_to_global_g
        seg_lengths = np.diff(offsets)

        # Compute posteriors from converged theta
        eff_len = locus_em.effective_lengths
        log_weights = (
            np.log(theta + _EM_LOG_EPSILON) - np.log(eff_len)
        )
        log_posteriors = log_liks + log_weights[t_indices]

        seg_max = np.maximum.reduceat(log_posteriors, offsets[:-1])
        log_posteriors -= np.repeat(seg_max, seg_lengths)
        posteriors = np.exp(log_posteriors)
        seg_sum = np.add.reduceat(posteriors, offsets[:-1])
        posteriors /= np.repeat(seg_sum, seg_lengths)

        gdna_count = 0.0

        for u in range(n_units):
            s, e = int(offsets[u]), int(offsets[u + 1])
            p = posteriors[s:e]
            t_seg = t_indices[s:e]

            is_mrna = t_seg < n_t
            is_nrna = (t_seg >= n_t) & (t_seg < gdna_base)
            is_gdna = t_seg >= gdna_base

            rna_mask = is_mrna | is_nrna
            p_rna_total = float(p[rna_mask].sum())
            has_shadow = is_gdna.any()

            if p_rna_total >= gdna_threshold or not has_shadow:
                # --- Assign to RNA ---
                # mRNA
                mrna_local = np.where(is_mrna)[0]
                if len(mrna_local) > 0:
                    p_mrna = p[mrna_local]
                    mrna_norm = p_mrna / max(p_rna_total, 1e-300)
                    # Map local transcript index → global
                    local_ts = t_seg[mrna_local]
                    global_ts = local_to_global_t[local_ts]
                    mrna_col = count_cols_arr[s + mrna_local]
                    np.add.at(
                        self.em_counts,
                        (global_ts, mrna_col),
                        mrna_norm,
                    )
                    max_conf = float(mrna_norm.max())
                    if max_conf >= confidence_threshold:
                        np.add.at(
                            self.em_high_conf_counts,
                            (global_ts, mrna_col),
                            mrna_norm,
                        )
                    # Confidence tracking
                    if self._em_posterior_sum is None:
                        self._em_posterior_sum = np.zeros(
                            self.num_transcripts, dtype=np.float64
                        )
                        self._em_n_assigned = np.zeros(
                            self.num_transcripts, dtype=np.float64
                        )
                    np.add.at(
                        self._em_posterior_sum,
                        global_ts, mrna_norm * mrna_norm,
                    )
                    np.add.at(self._em_n_assigned, global_ts, mrna_norm)

                # nRNA
                nrna_local = np.where(is_nrna)[0]
                if len(nrna_local) > 0:
                    p_nrna = p[nrna_local]
                    nrna_norm = p_nrna / max(p_rna_total, 1e-300)
                    # nRNA local idx = n_t + local_t → global transcript
                    local_nrna_ts = t_seg[nrna_local] - n_t
                    global_nrna_ts = local_to_global_t[local_nrna_ts]
                    np.add.at(self.nrna_em_counts, global_nrna_ts, nrna_norm)

            else:
                # --- Assign to gDNA (per-gene, then sum as locus total) ---
                gdna_local = np.where(is_gdna)[0]
                if len(gdna_local) > 0:
                    gdna_idx_arr = s + gdna_local
                    # Map local gene indices → global
                    local_gs = t_seg[gdna_local] - gdna_base
                    global_gs = local_to_global_g[local_gs]
                    p_gdna = p[gdna_local]
                    p_gdna_total = float(p_gdna.sum())
                    if p_gdna_total > 0:
                        gdna_norm = p_gdna / p_gdna_total
                    else:
                        gdna_norm = np.full(
                            len(gdna_local),
                            1.0 / len(gdna_local),
                            dtype=np.float64,
                        )
                    # Accumulate per-gene gDNA counts (for reporting)
                    np.add.at(self.gdna_exonic_em_counts, global_gs, gdna_norm)
                    np.add.at(self.gdna_em_counts, global_gs, gdna_norm)
                    gdna_count += 1.0

                # Locus attribution for reporting: use best transcript
                locus_t = locus_em.locus_t_indices[u]
                locus_ct = locus_em.locus_count_cols[u]
                if locus_t >= 0:
                    self.gdna_locus_counts[locus_t, locus_ct] += 1.0

        return gdna_count

    # ------------------------------------------------------------------
    # Confidence / posterior metrics
    # ------------------------------------------------------------------

    def posterior_mean(self) -> np.ndarray:
        """Per-transcript mean posterior at assignment.

        For each transcript, this is the average posterior probability
        at which a unit was assigned to it.  Returns NaN for
        transcripts with no EM assignments.

        Returns
        -------
        np.ndarray
            float64[num_transcripts]
        """
        n_assigned = self._em_n_assigned
        if n_assigned is None:
            return np.full(self.num_transcripts, np.nan)
        post_sum = self._em_posterior_sum
        with np.errstate(divide="ignore", invalid="ignore"):
            result = np.where(
                n_assigned > 0,
                post_sum / n_assigned,
                np.nan,
            )
        return result

    # ------------------------------------------------------------------
    # Output - primary counts
    # ------------------------------------------------------------------

    def get_counts_df(self, index) -> pd.DataFrame:
        """Primary transcript-level counts with identifiers.

        Columns: transcript_id, gene_id, gene_name, count,
        count_unique, count_spliced, count_em, count_high_conf,
        n_gdna, posterior_mean.
        """
        total = self.t_counts  # (N_t, 8)
        unique = self.unique_counts  # (N_t, 8)

        # Total count = sum across all 8 columns
        count_total = total.sum(axis=1)
        count_unique = unique.sum(axis=1)

        # Spliced = SPLICED_ANNOT + SPLICED_UNANNOT (both strands)
        count_spliced = total[:, list(SPLICED_COLS)].sum(axis=1)

        # EM count
        count_em = self.em_counts.sum(axis=1)

        # High-confidence count (unique + EM above threshold)
        count_high_conf = self.t_high_conf_counts.sum(axis=1)

        # Per-transcript gDNA locus attribution
        n_gdna = self.gdna_locus_counts.sum(axis=1)

        # Posterior mean
        pmean = self.posterior_mean()

        df = pd.DataFrame({
            "transcript_id": index.t_df["t_id"].values,
            "gene_id": index.t_df["g_id"].values,
            "gene_name": index.t_df["g_name"].values,
            "count": count_total,
            "count_unique": count_unique,
            "count_spliced": count_spliced,
            "count_em": count_em,
            "count_high_conf": count_high_conf,
            "n_gdna": n_gdna,
            "posterior_mean": pmean,
        })
        return df

    def get_gene_counts_df(self, index) -> pd.DataFrame:
        """Primary gene-level counts with three-state gDNA summary.

        Columns: gene_id, gene_name, count, count_unique,
        count_spliced, count_em, count_high_conf,
        n_nrna, n_gdna_exonic, n_gdna_intronic, n_gdna,
        n_antisense, gdna_rate.
        """
        t_to_g = index.t_to_g_arr
        total = self.t_counts
        unique = self.unique_counts

        n_genes = index.num_genes
        g_total = np.zeros((n_genes, NUM_SPLICE_STRAND_COLS), dtype=np.float64)
        np.add.at(g_total, t_to_g, total)

        g_unique = np.zeros((n_genes, NUM_SPLICE_STRAND_COLS), dtype=np.float64)
        np.add.at(g_unique, t_to_g, unique)

        count_total = g_total.sum(axis=1)
        count_unique = g_unique.sum(axis=1)

        count_spliced = g_total[:, list(SPLICED_COLS)].sum(axis=1)
        count_em_arr = np.zeros(n_genes, dtype=np.float64)
        np.add.at(count_em_arr, t_to_g, self.em_counts.sum(axis=1))

        # High-confidence counts aggregated to gene level
        count_hc_arr = np.zeros(n_genes, dtype=np.float64)
        np.add.at(
            count_hc_arr, t_to_g, self.t_high_conf_counts.sum(axis=1)
        )

        # nRNA shadow counts: aggregate per-transcript to per-gene
        # (nrna_init and nrna_em_counts are per-transcript)
        n_nrna_per_t = self.nrna_init + self.nrna_em_counts
        n_nrna = np.zeros(n_genes, dtype=np.float64)
        np.add.at(n_nrna, t_to_g, n_nrna_per_t)
        n_gdna_exonic = self.gdna_exonic_init + self.gdna_exonic_em_counts
        n_gdna_intronic = self.gdna_intronic_init + self.gdna_intronic_em_counts
        n_gdna = n_gdna_exonic + n_gdna_intronic

        # Antisense unique counts per gene
        t_antisense = unique[:, list(ANTISENSE_COLS)].sum(axis=1)
        n_antisense = np.zeros(n_genes, dtype=np.float64)
        np.add.at(n_antisense, t_to_g, t_antisense)

        # Pre-EM strand accumulators (gene-level, all single-gene frags)
        n_sense_all = self.gene_sense_all
        n_antisense_all = self.gene_antisense_all

        # Pre-EM intronic accumulators aggregated to gene level
        n_intronic_sense = np.zeros(n_genes, dtype=np.float64)
        np.add.at(
            n_intronic_sense, t_to_g,
            self.transcript_intronic_sense,
        )
        n_intronic_antisense = np.zeros(n_genes, dtype=np.float64)
        np.add.at(
            n_intronic_antisense, t_to_g,
            self.transcript_intronic_antisense,
        )

        # gDNA rate per gene
        denom = count_total + n_gdna
        with np.errstate(divide="ignore", invalid="ignore"):
            gdna_rate = np.where(denom > 0, n_gdna / denom, 0.0)

        df = pd.DataFrame({
            "gene_id": index.g_df["g_id"].values,
            "gene_name": index.g_df["g_name"].values,
            "count": count_total,
            "count_unique": count_unique,
            "count_spliced": count_spliced,
            "count_em": count_em_arr,
            "count_high_conf": count_hc_arr,
            "n_nrna": n_nrna,
            "n_gdna_exonic": n_gdna_exonic,
            "n_gdna_intronic": n_gdna_intronic,
            "n_gdna": n_gdna,
            "n_antisense": n_antisense,
            "n_sense_all": n_sense_all,
            "n_antisense_all": n_antisense_all,
            "n_intronic_sense": n_intronic_sense,
            "n_intronic_antisense": n_intronic_antisense,
            "gdna_rate": gdna_rate,
        })
        return df

    # ------------------------------------------------------------------
    # Output - detail (long format QC breakdown)
    # ------------------------------------------------------------------

    def get_detail_df(self, index) -> pd.DataFrame:
        """Detailed counts in long format for QC.

        Each row is a nonzero (transcript, category, source) combination.
        Columns: transcript_id, gene_id, category, source, count.
        """
        t_ids = index.t_df["t_id"].values
        g_ids = index.t_df["g_id"].values

        frames = []
        for source_name, counts in (
            ("unique", self.unique_counts),
            ("em", self.em_counts),
        ):
            # Sum sense + antisense per category -> (N_t, 4)
            cat_counts = np.zeros(
                (self.num_transcripts, len(SpliceType)),
                dtype=np.float64,
            )
            for cat in SpliceType:
                sense_col = SpliceStrandCol.from_category(cat, False)
                anti_col = SpliceStrandCol.from_category(cat, True)
                cat_counts[:, int(cat)] = (
                    counts[:, sense_col] + counts[:, anti_col]
                )

            nz_t, nz_cat = np.nonzero(cat_counts)
            if len(nz_t) == 0:
                continue
            cat_order = [c.name.lower() for c in SpliceType]
            frames.append(
                pd.DataFrame({
                    "transcript_id": t_ids[nz_t],
                    "gene_id": g_ids[nz_t],
                    "category": pd.Categorical(
                        [SpliceType(c).name.lower() for c in nz_cat],
                        categories=cat_order,
                    ),
                    "source": source_name,
                    "count": cat_counts[nz_t, nz_cat],
                })
            )

        if not frames:
            return pd.DataFrame(
                columns=[
                    "transcript_id", "gene_id",
                    "category", "source", "count",
                ]
            )
        return pd.concat(frames, ignore_index=True)

    # ------------------------------------------------------------------
    # Output - gDNA summary dict
    # ------------------------------------------------------------------

    def gdna_summary(self) -> dict:
        """Summary dict of three-pool contamination estimates."""
        return {
            "nrna_init_total": float(self.nrna_init.sum()),
            "nrna_em_total": float(self.nrna_em_counts.sum()),
            "gdna_exonic_init": float(self.gdna_exonic_init.sum()),
            "gdna_exonic_em": float(self.gdna_exonic_em_counts.sum()),
            "gdna_intronic_init": float(self.gdna_intronic_init.sum()),
            "gdna_intronic_em": float(self.gdna_intronic_em_counts.sum()),
            "gdna_unique_count": float(self.gdna_unique_count),
            "gdna_em_count": float(self.gdna_em_count),
            "gdna_total": float(self.gdna_total),
            "gdna_contamination_rate": float(
                round(self.gdna_contamination_rate, 6)
            ),
            "rna_unique_total": float(self.unique_counts.sum()),
            "rna_em_total": float(self.em_counts.sum()),
            "gene_sense_all_total": float(self.gene_sense_all.sum()),
            "gene_antisense_all_total": float(
                self.gene_antisense_all.sum()
            ),
            "transcript_intronic_sense_total": float(
                self.transcript_intronic_sense.sum()
            ),
            "transcript_intronic_antisense_total": float(
                self.transcript_intronic_antisense.sum()
            ),
        }
