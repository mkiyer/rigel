"""
hulkrna.pipeline — Single-pass BAM counting pipeline with EM.

Architecture
------------
The pipeline reads the BAM file **once** and processes counts in
two logical stages:

**BAM Scan**: Parse all fragments, resolve each against the
reference index, train strand and insert-size models from
unique-mapper fragments, and buffer all resolved fragments into a
memory-efficient columnar buffer (``FragmentBuffer``).

**Count Assignment**: Iterate the buffer once to:

1. **Unique assignment** — deterministic count += 1 for unambiguous
   SPLICED_ANNOT fragments (annotated splice junctions definitively
   prove RNA origin).
2. **Pre-compute EM data** — for every other fragment, compute the
   data likelihood for each candidate transcript *and* a single gDNA
   pseudo-component, then store in CSR arrays.
3. **EM iteration** — run vectorized Expectation-Maximization over
   *all* ambiguous fragments simultaneously to estimate transcript
   *and gDNA* abundances.  The gDNA component competes with
   transcripts for probability mass.
4. **Expected-value assignment** — use the converged EM posteriors to
   distribute fractional counts across candidates (transcript
   or gDNA).

Each fragment contributes exactly **one count** (1.0) distributed
across components proportional to posterior probability.  The EM
approach follows the standard algorithm used by RSEM, Salmon, and
Kallisto, extended with a genomic DNA contamination model.

The columnar buffer stores fragment data at ~40-50 bytes per fragment
(vs. ~600 bytes for Python ``ResolvedFragment`` objects).  When
memory exceeds a configurable threshold, chunks are spilled to disk
as Arrow IPC (Feather v2) files with LZ4 compression.
"""

import logging
from dataclasses import dataclass
from pathlib import Path

import numpy as np

from .bam import parse_bam_file, detect_sj_strand_tag
from .buffer import (
    FragmentBuffer,
    FRAG_UNIQUE,
    FRAG_ISOFORM_AMBIG,
    FRAG_GENE_AMBIG,
    FRAG_MULTIMAPPER,
    FRAG_CHIMERIC,
)
from .categories import SpliceType
from .counter import ReadCounter, EMData, Locus, LocusEMData
from .fragment import Fragment
from .types import ChimeraType, Strand
from .index import HulkIndex
from .insert_model import InsertSizeModels
from .resolution import (
    fragment_insert_size,
    pair_multimapper_reads,
    resolve_fragment,
)
from .stats import PipelineStats
from .strand_model import StrandModels

logger = logging.getLogger(__name__)

# Floor value for log-safe clamping to avoid log(0).
_LOG_SAFE_FLOOR = 1e-10

# Default gDNA splice penalty for SPLICED_UNANNOT fragments.
# Most unannotated splice junctions are real; a small penalty allows
# gDNA to compete only weakly for these fragments.
_DEFAULT_GDNA_SPLICE_PENALTY_UNANNOT = 0.01
DEFAULT_GDNA_SPLICE_PENALTY_UNANNOT = _DEFAULT_GDNA_SPLICE_PENALTY_UNANNOT


# ---------------------------------------------------------------------------
# Pipeline result
# ---------------------------------------------------------------------------

@dataclass
class PipelineResult:
    """Complete output of the three-phase pipeline."""

    stats: PipelineStats
    strand_models: StrandModels
    insert_models: InsertSizeModels
    counter: ReadCounter


# ---------------------------------------------------------------------------
# BAM Scan: resolve, train models, buffer
# ---------------------------------------------------------------------------

def scan_and_buffer(
    bam_iter,
    index: HulkIndex,
    *,
    skip_duplicates: bool = True,
    include_multimap: bool = False,
    log_every: int = 1_000_000,
    insert_size_max: int = 1000,
    chunk_size: int = 1_000_000,
    max_memory_bytes: int = 2 * 1024**3,
    spill_dir: Path | None = None,
    sj_strand_tag: str | tuple[str, ...] = "XS",
    overlap_min_frac: float = 0.99,
) -> tuple[PipelineStats, StrandModels, InsertSizeModels, FragmentBuffer]:
    """Single-pass BAM scan: resolve fragments, train models, buffer results.

    Reads the BAM once.  For each fragment:

    1. Build a ``Fragment`` from the read pair.
    2. Resolve against the reference index.
    3. Train strand and insert-size models (unique mappers only).
    4. Buffer all resolved fragments into the columnar buffer.
       Each fragment receives a ``frag_id`` that groups alignments
       of the same molecule for Phase 4 multimapper handling.

    Two strand models are trained (unique mappers only):

    - **exonic_spliced** *(pure RNA)*: from SPLICED_ANNOT fragments
      with unique gene and unambiguous strands.  SJ strand is ground
      truth.  Gold-standard measure of library strand specificity.
      Used for all RNA transcript scoring.
    - **intergenic** *(~100% gDNA)*: from intergenic fragments.
      POS reference convention (n_same = POS-aligned, n_opposite =
      NEG-aligned).  Expected ~50/50 since gDNA is unstranded.
      Used for gDNA shadow scoring.

    Models are trained exclusively from unique-mapper fragments
    (NH = 1) regardless of the *include_multimap* setting.

    Parameters
    ----------
    bam_iter
        Iterator over ``pysam.AlignedSegment`` objects.
    index : HulkIndex
        The loaded reference index.
    skip_duplicates : bool
        Discard reads marked as duplicates (default True).
    include_multimap : bool
        Include multimapping reads (NH > 1) for Phase 4 counting
        (default False).  Model training always excludes
        multimappers.
    log_every : int
        Log progress every *log_every* read-name groups.
    insert_size_max : int
        Maximum insert size for the histogram model.
    chunk_size : int
        Fragments per buffer chunk (default 1M).
    max_memory_bytes : int
        Max memory for in-memory buffer chunks before disk spill
        (default 2 GiB).  Set to 0 to disable spilling.
    spill_dir : Path or None
        Directory for spilled chunk files (default: system temp dir).
    sj_strand_tag : str or tuple of str
        BAM tag(s) for splice-junction strand (``"XS"`` for STAR,
        ``"ts"`` for minimap2; default ``"XS"``).  A tuple is
        checked in order; the first present tag on each read wins.

    Returns
    -------
    tuple[PipelineStats, StrandModels, InsertSizeModels, FragmentBuffer]
        All resolved fragments (unique and multimapper) are stored in
        the buffer with ``frag_id`` for grouping multimapper hits.
    """
    stats = PipelineStats()
    bam_stats = stats.as_bam_stats_dict()

    strand_models = StrandModels()
    insert_models = InsertSizeModels(max_size=insert_size_max)
    buffer = FragmentBuffer(
        t_to_g_arr=index.t_to_g_arr,
        chunk_size=chunk_size,
        max_memory_bytes=max_memory_bytes,
        spill_dir=spill_dir,
    )

    logger.info("[START] Scanning BAM → resolve + train models + buffer")

    frag_id = 0
    for nh, hits, sec_r1, sec_r2 in parse_bam_file(
        bam_iter,
        bam_stats,
        skip_duplicates=skip_duplicates,
        include_multimap=include_multimap,
    ):
        # Pair secondary R1/R2 locations using transcript-aware
        # resolve-then-pair.  Each secondary is resolved individually
        # and pairs are formed by transcript-set intersection, with
        # same-reference proximity as fallback.
        secondary_pairs: list[tuple[list, list]] = []
        if sec_r1 or sec_r2:
            secondary_pairs = pair_multimapper_reads(
                sec_r1, sec_r2, index,
                sj_strand_tag=sj_strand_tag,
                overlap_min_frac=overlap_min_frac,
            )

        all_hits = list(hits) + secondary_pairs

        # Use the actual number of alignment hits rather than relying
        # solely on the NH tag.  minimap2 often does not set NH when
        # reporting secondary alignments, so the BAM may have NH=1
        # even when multiple alignment locations exist.  Using
        # max(nh, len(all_hits)) ensures that secondary alignments are
        # correctly classified as multimappers regardless of tag
        # accuracy.  This prevents each secondary alignment from
        # being counted as an independent unique fragment, which
        # would inflate total counts (e.g. 50 k → 76 k for the HBB
        # paralog cluster).
        num_hits = max(nh, len(all_hits))
        is_unique_mapper = num_hits == 1
        n_buffered_mm = 0

        for r1_reads, r2_reads in all_hits:
            frag = Fragment.from_reads(r1_reads, r2_reads, sj_strand_tag=sj_strand_tag)
            stats.n_fragments += 1

            if not frag.exons:
                continue

            result = resolve_fragment(
                frag, index, overlap_min_frac=overlap_min_frac,
            )

            if result is None:
                # --- Intergenic: deterministic gDNA assignment ---
                if frag.introns:
                    stats.n_intergenic_spliced += 1
                else:
                    stats.n_intergenic_unspliced += 1
                # Train intergenic models (unique mappers only)
                if is_unique_mapper:
                    isize = fragment_insert_size(frag)
                    if isize > 0:
                        insert_models.observe(isize, splice_type=None)
                        stats.n_insert_intergenic += 1
                    # Intergenic strand model: record POS/NEG distribution
                    # using POS as synthetic reference so that
                    # n_same = POS-aligned, n_opposite = NEG-aligned.
                    intergenic_strand = Strand.NONE
                    for eb in frag.exons:
                        intergenic_strand |= Strand(eb.strand)
                    if intergenic_strand in (Strand.POS, Strand.NEG):
                        strand_models.intergenic.observe(
                            intergenic_strand, Strand.POS,
                        )
                continue

            # Set num_hits from pairs list length
            result.num_hits = num_hits

            # --- Handle chimeric fragments ---
            if result.is_chimeric:
                ct = result.chimera_type
                stats.n_chimeric += 1
                if ct == ChimeraType.TRANS:
                    stats.n_chimeric_trans += 1
                elif ct == ChimeraType.CIS_STRAND_SAME:
                    stats.n_chimeric_cis_strand_same += 1
                elif ct == ChimeraType.CIS_STRAND_DIFF:
                    stats.n_chimeric_cis_strand_diff += 1
                # Buffer chimeric fragments for reporting, but skip
                # model training since they are not countable.
                buffer.append(result, frag_id=frag_id)
                continue

            # --- Stats: overlap type ---
            stats.n_with_exon += 1
            if result.splice_type == SpliceType.SPLICED_ANNOT:
                stats.n_with_annotated_sj += 1
            elif result.splice_type == SpliceType.SPLICED_UNANNOT:
                stats.n_with_unannotated_sj += 1

            # --- Stats: gene ambiguity ---
            if result.is_unique_gene:
                stats.n_unique_gene += 1
            else:
                stats.n_multi_gene += 1

            if is_unique_mapper:
                # --- Train models (unique mappers only) ---
                # Pure RNA strand model (SPLICED_ANNOT + SJ strand)
                if result.is_strand_qualified:
                    strand_models.exonic_spliced.observe(
                        result.exon_strand, result.sj_strand,
                    )
                    stats.n_strand_trained += 1
                elif result.splice_type != SpliceType.SPLICED_ANNOT:
                    stats.n_strand_skipped_no_sj += 1
                elif not result.is_unique_gene:
                    stats.n_strand_skipped_multi_gene += 1
                else:
                    stats.n_strand_skipped_ambiguous += 1

                # Insert size model
                if result.insert_size > 0:
                    insert_models.observe(
                        result.insert_size, result.splice_type
                    )
                    stats.n_insert_unambiguous += 1
                else:
                    stats.n_insert_ambiguous += 1

            # --- Buffer ALL resolved fragments with frag_id ---
            buffer.append(result, frag_id=frag_id)

            if not is_unique_mapper:
                n_buffered_mm += 1

        # Track multimapper molecule stats
        if n_buffered_mm > 0:
            stats.n_multimapper_groups += 1
            stats.n_multimapper_alignments += n_buffered_mm

        frag_id += 1
        if frag_id % log_every == 0:
            logger.debug(
                f"  {frag_id:,} read-name groups, "
                f"{stats.n_fragments:,} fragments, "
                f"{strand_models.n_observations:,} strand obs, "
                f"{buffer.total_fragments:,} buffered"
            )

    buffer.finalize()

    logger.info(
        f"[DONE] Scan: {stats.n_fragments:,} fragments → "
        f"{stats.n_unique_gene:,} unique-gene, "
        f"{stats.n_multi_gene:,} multi-gene, "
        f"{stats.n_intergenic:,} intergenic, "
        f"{buffer.total_fragments:,} buffered "
        f"({buffer.memory_bytes / 1024**2:.1f} MB in memory, "
        f"{buffer.n_spilled} chunks spilled), "
        f"{stats.n_multimapper_groups:,} multimapper molecules"
    )
    strand_models.log_summary()
    insert_models.log_summary()

    return stats, strand_models, insert_models, buffer


# ---------------------------------------------------------------------------
# EM scoring helper
# ---------------------------------------------------------------------------


def _score_candidate(
    exon_strand: int,
    t_strand: int,
    splice_type: int,
    insert_size: int,
    strand_models: StrandModels,
    insert_models: InsertSizeModels,
    overlap_frac: float = 1.0,
    overlap_exponent: float = 1.0,
) -> tuple[float, int]:
    """Compute data log-likelihood and count column for one mRNA candidate.

    Likelihood: ``log(P_strand) + log(P_insert) + k × log(exon_frac)``.

    Uses the ``exonic_spliced`` strand model (RNA gold standard) and
    the global insert size model.

    Returns
    -------
    log_lik : float
    count_col_idx : int
    """
    from .categories import SpliceStrandCol

    sm = strand_models.exonic_spliced
    p_strand = sm.strand_likelihood(exon_strand, Strand(t_strand))

    log_p_insert = (
        insert_models.global_model.log_likelihood(insert_size)
        if insert_size > 0
        else 0.0
    )

    log_lik = (
        np.log(max(p_strand, _LOG_SAFE_FLOOR))
        + log_p_insert
        + overlap_exponent * np.log(max(overlap_frac, _LOG_SAFE_FLOOR))
    )

    anti = p_strand < 0.5
    count_col_idx = SpliceStrandCol.from_category(splice_type, anti)

    return log_lik, count_col_idx


# Default gDNA splice penalties per SpliceType.
# INTRON and UNSPLICED are fully compatible with gDNA (penalty 1.0).
# SPLICED_UNANNOT gets a small penalty (most are real SJs, but some
# UNSPLICED is fully compatible with gDNA (penalty 1.0).
# SPLICED_UNANNOT gets a small penalty (most are real SJs, but some
# are alignment artifacts from gDNA).
# SPLICED_ANNOT never competes with gDNA (handled upstream).
_GDNA_SPLICE_PENALTIES = {
    SpliceType.UNSPLICED: 1.0,
    SpliceType.SPLICED_UNANNOT: _DEFAULT_GDNA_SPLICE_PENALTY_UNANNOT,
    SpliceType.SPLICED_ANNOT: 0.0,  # never used
}

# Default overlap exponents per SpliceType.
# For UNSPLICED fragments, exonic overlap fraction is the primary signal
# distinguishing RNA from gDNA — a steep exponent creates a near-hard
# threshold (~95% overlap required) while still allowing the EM to
# handle alignment noise and edge cases.  For spliced fragments,
# splice junctions already prove RNA origin; a mild exponent suffices
# for transcript discrimination.
_DEFAULT_OVERLAP_EXPONENTS = {
    SpliceType.UNSPLICED: 10.0,
    SpliceType.SPLICED_UNANNOT: 1.0,
    SpliceType.SPLICED_ANNOT: 1.0,
}


def _score_gdna_candidate(
    exon_strand: int,
    splice_type: int,
    insert_size: int,
    strand_models: StrandModels,
    insert_models: InsertSizeModels,
    gdna_splice_penalties: dict | None = None,
) -> float:
    """Compute data log-likelihood for the gDNA pseudo-component.

    Likelihood: ``log(P_strand) + log(P_insert) + log(splice_penalty)``.

    - **Strand**: intergenic model with POS reference convention.
    - **Insert size**: global model.
    - **Splice penalty**: UNSPLICED=1.0, SPLICED_UNANNOT=0.01.

    Returns
    -------
    float
    """
    penalties = gdna_splice_penalties or _GDNA_SPLICE_PENALTIES
    splice_pen = penalties.get(SpliceType(splice_type), 1.0)

    p_strand = strand_models.intergenic.strand_likelihood(
        exon_strand, Strand.POS,
    )

    log_p_insert = (
        insert_models.global_model.log_likelihood(insert_size)
        if insert_size > 0
        else 0.0
    )

    return (
        np.log(max(p_strand, _LOG_SAFE_FLOOR))
        + log_p_insert
        + np.log(max(splice_pen, _LOG_SAFE_FLOOR))
    )


def _score_nrna_candidate(
    exon_strand: int,
    gene_strand: int,
    insert_size: int,
    strand_models: StrandModels,
    insert_models: InsertSizeModels,
    genic_frac: float = 1.0,
    overlap_exponent: float = 1.0,
) -> float:
    """Compute data log-likelihood for a nascent RNA (nRNA) candidate.

    Likelihood: ``log(P_strand) + log(P_insert) + k × log(genic_frac)``.

    - **Strand**: ``exonic_spliced`` model (RNA is stranded).
    - **Insert size**: global model.
    - **Overlap**: ``genic_frac`` (exon + intron coverage).

    Returns
    -------
    float
    """
    p_strand = strand_models.exonic_spliced.strand_likelihood(
        exon_strand, Strand(gene_strand),
    )

    log_p_insert = (
        insert_models.global_model.log_likelihood(insert_size)
        if insert_size > 0
        else 0.0
    )

    return (
        np.log(max(p_strand, _LOG_SAFE_FLOOR))
        + log_p_insert
        + overlap_exponent * np.log(max(genic_frac, _LOG_SAFE_FLOOR))
    )


# ---------------------------------------------------------------------------
# Buffer scan + EM data construction
# ---------------------------------------------------------------------------


def _scan_and_build_em_data(
    buffer: FragmentBuffer,
    index: HulkIndex,
    strand_models: StrandModels,
    insert_models: InsertSizeModels,
    counter: ReadCounter,
    stats: PipelineStats,
    log_every: int,
    gdna_splice_penalties: dict | None = None,
    enable_gdna_shadows: bool = True,
    overlap_exponents: dict | None = None,
) -> EMData:
    """Single buffer pass: assign uniques + build three-pool EM data.

    Three-pool fragment routing:

    - **SPLICED_ANNOT + FRAG_UNIQUE**: deterministic mRNA assignment.
    - **All other** (UNSPLICED, SPLICED_UNANNOT, non-unique SPLICED_ANNOT):
      transcript candidates (mRNA) + per-transcript nRNA shadow(s) +
      per-gene gDNA exonic shadow(s).

    EM component indices:
      [0, N_t)                     — mRNA transcripts
      [N_t, 2*N_t)                 — nRNA per transcript
      [2*N_t, 2*N_t + 2*N_g)      — gDNA per gene
    """
    nrna_base = counter.nrna_base_index
    gdna_exonic_base = counter.gdna_exonic_base_index
    t_to_g = index.t_to_g_arr
    _overlap_exponents = overlap_exponents or _DEFAULT_OVERLAP_EXPONENTS

    # Accumulation lists for CSR (converted to arrays at end)
    offsets: list[int] = [0]
    t_indices_list: list[int] = []
    log_liks_list: list[float] = []
    count_cols_list: list[int] = []

    # Per-unit locus tracking (best transcript per EM unit)
    locus_t_list: list[int] = []
    locus_ct_list: list[int] = []

    # Multimapper group state
    mm_pending: list = []
    mm_fid: int = -1

    def _add_transcript_candidates(bf) -> tuple[float, int]:
        """Add all transcript candidates for an exonic-pool fragment."""
        best_ll = -np.inf
        best_ct = 0
        oexp = _overlap_exponents.get(SpliceType(bf.splice_type), 1.0)
        fl = bf.frag_length if bf.frag_length > 0 else 1
        for k, t_idx in enumerate(bf.t_inds):
            t_idx_int = int(t_idx)
            t_strand = int(index.t_to_strand_arr[t_idx_int])
            ebp = int(bf.exon_bp[k]) if bf.exon_bp is not None else fl
            ofrac = max(ebp / fl, _LOG_SAFE_FLOOR)
            log_lik, ct = _score_candidate(
                bf.exon_strand,
                t_strand,
                bf.splice_type,
                bf.insert_size,
                strand_models,
                insert_models,
                ofrac,
                oexp,
            )
            t_indices_list.append(t_idx_int)
            log_liks_list.append(log_lik)
            count_cols_list.append(ct)
            if log_lik > best_ll:
                best_ll = log_lik
                best_ct = ct
        return best_ll, best_ct

    def _add_exonic_gdna_candidates(bf, unit_start: int) -> None:
        """Add per-gene gDNA exonic shadow candidates."""
        unit_end = len(t_indices_list)
        if unit_start >= unit_end:
            return

        gdna_ll = _score_gdna_candidate(
            bf.exon_strand, bf.splice_type, bf.insert_size,
            strand_models, insert_models,
            gdna_splice_penalties,
        )

        seen_genes: set[int] = set()
        for j in range(unit_start, unit_end):
            t_idx = t_indices_list[j]
            if t_idx < nrna_base:
                seen_genes.add(int(t_to_g[t_idx]))

        for g_idx in sorted(seen_genes):
            shadow_idx = gdna_exonic_base + g_idx
            t_indices_list.append(shadow_idx)
            log_liks_list.append(gdna_ll)
            count_cols_list.append(0)

    def _add_nrna_candidates(bf) -> None:
        """Add per-transcript nRNA (nascent RNA) shadow candidates.

        For each transcript candidate, adds one nRNA shadow scored with
        that transcript's own ``genic_frac`` (exon + intron coverage).
        Uses the RNA strand model and global insert model.

        nRNA is modeled as a transcript-level event: each transcriptional
        unit produces its own pre-mRNA isoform, so the nRNA shadow index
        is ``nrna_base + t_idx`` (not a gene-level shadow).
        """
        oexp = _overlap_exponents.get(SpliceType(bf.splice_type), 1.0)
        fl = bf.frag_length if bf.frag_length > 0 else 1

        for k, t_idx in enumerate(bf.t_inds):
            t_idx_int = int(t_idx)
            g_idx = int(t_to_g[t_idx_int])
            gene_strand = int(index.g_to_strand_arr[g_idx])
            ebp = int(bf.exon_bp[k]) if bf.exon_bp is not None else fl
            ibp = int(bf.intron_bp[k]) if bf.intron_bp is not None else 0
            gf = max((ebp + ibp) / fl, _LOG_SAFE_FLOOR)
            nrna_ll = _score_nrna_candidate(
                bf.exon_strand, gene_strand, bf.insert_size,
                strand_models, insert_models,
                gf, oexp,
            )
            nrna_idx = nrna_base + t_idx_int
            t_indices_list.append(nrna_idx)
            log_liks_list.append(nrna_ll)
            count_cols_list.append(0)

    def _flush_mm_group() -> None:
        """Flush accumulated multimapper alignments as one EM unit.

        All hits contribute transcript candidates + gDNA exonic shadow.
        SPLICED_ANNOT hits bypass shadows.
        """
        any_spliced_annot = False
        has_exonic = False
        unit_start = offsets[-1]

        for bf in mm_pending:
            cat = SpliceType(bf.splice_type)
            if cat == SpliceType.SPLICED_ANNOT:
                any_spliced_annot = True
            else:
                has_exonic = True

        # Collect best (log_lik, count_col) per transcript across all hits
        best_per_t: dict[int, tuple[float, int]] = {}
        for bf in mm_pending:
            cat = SpliceType(bf.splice_type)
            oexp = _overlap_exponents.get(cat, 1.0)
            fl = bf.frag_length if bf.frag_length > 0 else 1
            for k, t_idx in enumerate(bf.t_inds):
                t_idx_int = int(t_idx)
                t_strand = int(index.t_to_strand_arr[t_idx_int])
                ebp = int(bf.exon_bp[k]) if bf.exon_bp is not None else fl
                ofrac = max(ebp / fl, _LOG_SAFE_FLOOR)
                log_lik, ct = _score_candidate(
                    bf.exon_strand,
                    t_strand,
                    bf.splice_type,
                    bf.insert_size,
                    strand_models,
                    insert_models,
                    ofrac,
                    oexp,
                )
                prev = best_per_t.get(t_idx_int)
                if prev is None or log_lik > prev[0]:
                    best_per_t[t_idx_int] = (log_lik, ct)

        # Append deduplicated transcript candidates
        _best_ll = -np.inf
        _best_t = -1
        _best_ct = 0
        for t_idx_int, (log_lik, ct) in best_per_t.items():
            t_indices_list.append(t_idx_int)
            log_liks_list.append(log_lik)
            count_cols_list.append(ct)
            if log_lik > _best_ll:
                _best_ll = log_lik
                _best_t = t_idx_int
                _best_ct = ct

        # Add shadows based on fragment types
        if enable_gdna_shadows and not any_spliced_annot:
            seen_genes: set[int] = set()

            # Exonic gDNA shadows from all hits
            if has_exonic:
                best_gdna_ll = -np.inf
                for bf in mm_pending:
                    cat = SpliceType(bf.splice_type)
                    if cat == SpliceType.SPLICED_ANNOT:
                        continue
                    gdna_ll = _score_gdna_candidate(
                        bf.exon_strand, bf.splice_type, bf.insert_size,
                        strand_models, insert_models,
                        gdna_splice_penalties,
                    )
                    if gdna_ll > best_gdna_ll:
                        best_gdna_ll = gdna_ll
                    for k, t_idx in enumerate(bf.t_inds):
                        g_idx = int(t_to_g[int(t_idx)])
                        seen_genes.add(g_idx)

                if best_gdna_ll > -np.inf:
                    for g_idx in sorted(seen_genes):
                        shadow_idx = gdna_exonic_base + g_idx
                        t_indices_list.append(shadow_idx)
                        log_liks_list.append(best_gdna_ll)
                        count_cols_list.append(0)

            # nRNA shadows: one per transcript, scored with
            # that transcript's own genic_frac
            for bf in mm_pending:
                cat = SpliceType(bf.splice_type)
                if cat == SpliceType.SPLICED_ANNOT:
                    continue
                oexp = _overlap_exponents.get(cat, 1.0)
                fl = bf.frag_length if bf.frag_length > 0 else 1
                for k, t_idx in enumerate(bf.t_inds):
                    t_idx_int = int(t_idx)
                    if t_idx_int not in best_per_t:
                        continue
                    g_idx = int(t_to_g[t_idx_int])
                    gene_strand = int(index.g_to_strand_arr[g_idx])
                    ebp = int(bf.exon_bp[k]) if bf.exon_bp is not None else fl
                    ibp = int(bf.intron_bp[k]) if bf.intron_bp is not None else 0
                    gf = max((ebp + ibp) / fl, _LOG_SAFE_FLOOR)
                    nrna_ll = _score_nrna_candidate(
                        bf.exon_strand, gene_strand,
                        bf.insert_size,
                        strand_models, insert_models,
                        gf, oexp,
                    )
                    nrna_idx = nrna_base + t_idx_int
                    t_indices_list.append(nrna_idx)
                    log_liks_list.append(nrna_ll)
                    count_cols_list.append(0)

        offsets.append(len(t_indices_list))
        locus_t_list.append(_best_t)
        locus_ct_list.append(_best_ct)

    n_processed = 0
    for chunk in buffer.iter_chunks():
        frag_classes = chunk.fragment_classes

        for i in range(chunk.size):
            fc = frag_classes[i]

            if fc == FRAG_CHIMERIC:
                continue

            bf = chunk[i]
            is_spliced_annot = bf.splice_type == int(SpliceType.SPLICED_ANNOT)

            # --- Pre-EM strand/intronic accumulation ---
            # Independent of EM routing; counts all single-gene
            # fragments for gDNA init (gene-level antisense) and
            # nRNA init (transcript-level intronic).
            if fc == FRAG_UNIQUE or fc == FRAG_ISOFORM_AMBIG:
                _g_idx = int(t_to_g[int(bf.t_inds[0])])
                _gene_strand = int(index.g_to_strand_arr[_g_idx])
                _is_anti = counter.is_antisense(
                    bf.exon_strand, _gene_strand,
                    strand_models.exonic_spliced,
                )

                # Gene-level sense/antisense (for gDNA init).
                # Only UNSPLICED fragments contribute: gDNA cannot
                # produce splice junctions, so spliced antisense
                # is RNA (often from an overlapping antisense gene).
                # Both sense and antisense are restricted to UNSPLICED
                # for symmetric correction.
                _is_unspliced = (
                    bf.splice_type == int(SpliceType.UNSPLICED)
                )
                if _is_unspliced:
                    if _is_anti:
                        counter.gene_antisense_all[_g_idx] += 1.0
                    else:
                        counter.gene_sense_all[_g_idx] += 1.0

                # Transcript-level intronic (for nRNA init)
                _n_cand = len(bf.t_inds)
                _weight = 1.0 / _n_cand
                for _k, _t_idx in enumerate(bf.t_inds):
                    _t_idx_int = int(_t_idx)
                    _has_intron = (
                        bf.intron_bp is not None
                        and bf.intron_bp[_k] > 0
                    )
                    if _has_intron:
                        if _is_anti:
                            counter.transcript_intronic_antisense[
                                _t_idx_int
                            ] += _weight
                        else:
                            counter.transcript_intronic_sense[
                                _t_idx_int
                            ] += _weight

            if fc == FRAG_UNIQUE and is_spliced_annot:
                # --- Deterministic: SPLICED_ANNOT + unique ---
                counter.assign_unique(bf, index, strand_models)
                stats.deterministic_unique_units += 1

            elif fc == FRAG_MULTIMAPPER:
                fid = int(chunk.frag_id[i])
                if fid != mm_fid:
                    if mm_pending:
                        _flush_mm_group()
                        stats.em_routed_multimapper_units += 1
                    mm_fid = fid
                    mm_pending.clear()
                    mm_pending.append(bf)
                else:
                    mm_pending.append(bf)

            else:
                # --- Three-pool: mRNA + nRNA + gDNA candidates ---
                unit_start = offsets[-1]
                best_ll, best_ct = _add_transcript_candidates(bf)

                unit_end = len(t_indices_list)
                _best_ll = -np.inf
                _best_t = -1
                _best_ct = 0
                for j in range(unit_start, unit_end):
                    if log_liks_list[j] > _best_ll:
                        _best_ll = log_liks_list[j]
                        _best_t = t_indices_list[j]
                        _best_ct = count_cols_list[j]

                if enable_gdna_shadows and not is_spliced_annot:
                    _add_nrna_candidates(bf)
                    _add_exonic_gdna_candidates(bf, unit_start)

                if len(t_indices_list) > offsets[-1]:
                    offsets.append(len(t_indices_list))
                    locus_t_list.append(_best_t)
                    locus_ct_list.append(_best_ct)

                if fc == FRAG_UNIQUE:
                    stats.em_routed_unique_units += 1
                elif fc == FRAG_ISOFORM_AMBIG:
                    stats.em_routed_isoform_ambig_units += 1
                else:
                    stats.em_routed_gene_ambig_units += 1

            n_processed += 1
            if n_processed % log_every == 0:
                logger.debug(
                    f"  Scan: {n_processed:,} / "
                    f"{buffer.total_fragments:,}"
                )

    # Flush last multimapper group
    if mm_pending:
        _flush_mm_group()
        stats.em_routed_multimapper_units += 1

    n_units = len(offsets) - 1
    n_candidates = len(t_indices_list)

    return EMData(
        offsets=np.array(offsets, dtype=np.int64),
        t_indices=np.array(t_indices_list, dtype=np.int32),
        log_liks=np.array(log_liks_list, dtype=np.float64),
        count_cols=np.array(count_cols_list, dtype=np.uint8),
        locus_t_indices=np.array(locus_t_list, dtype=np.int32),
        locus_count_cols=np.array(locus_ct_list, dtype=np.uint8),
        n_units=n_units,
        n_candidates=n_candidates,
        nrna_base_index=nrna_base,
        gdna_exonic_base_index=gdna_exonic_base,
    )


# ---------------------------------------------------------------------------
# Locus builder: union-find on fragment→transcript connectivity
# ---------------------------------------------------------------------------


class _UnionFind:
    """Weighted quick-union with path compression."""

    __slots__ = ("parent", "rank")

    def __init__(self, n: int):
        self.parent = np.arange(n, dtype=np.int32)
        self.rank = np.zeros(n, dtype=np.int32)

    def find(self, x: int) -> int:
        root = x
        while self.parent[root] != root:
            root = self.parent[root]
        # Path compression
        while self.parent[x] != root:
            self.parent[x], x = root, self.parent[x]
        return root

    def union(self, a: int, b: int) -> None:
        ra, rb = self.find(a), self.find(b)
        if ra == rb:
            return
        if self.rank[ra] < self.rank[rb]:
            ra, rb = rb, ra
        self.parent[rb] = ra
        if self.rank[ra] == self.rank[rb]:
            self.rank[ra] += 1


def _merge_intervals(intervals: list[tuple[str, int, int]]) -> list[tuple[str, int, int]]:
    """Merge overlapping/adjacent genomic intervals, grouping by reference.

    Parameters
    ----------
    intervals : list of (ref, start, end)

    Returns
    -------
    list of (ref, start, end)
        Sorted, non-overlapping merged intervals.
    """
    if not intervals:
        return []

    # Group by ref
    from collections import defaultdict
    by_ref: dict[str, list[tuple[int, int]]] = defaultdict(list)
    for ref, start, end in intervals:
        by_ref[ref].append((start, end))

    merged = []
    for ref in sorted(by_ref):
        segs = sorted(by_ref[ref])
        cur_s, cur_e = segs[0]
        for s, e in segs[1:]:
            if s <= cur_e:
                cur_e = max(cur_e, e)
            else:
                merged.append((ref, cur_s, cur_e))
                cur_s, cur_e = s, e
        merged.append((ref, cur_s, cur_e))
    return merged


def _build_loci(
    em_data,
    index: HulkIndex,
    counter,
    strand_models,
) -> list:
    """Build loci as connected components of transcripts linked by fragments.

    Uses union-find on transcript sets from each EM unit.  Returns a list
    of ``Locus`` objects with gDNA footprint computed from transcript
    genomic extents (approximation of fragment cluster footprint).

    Parameters
    ----------
    em_data : EMData
        Global EM data from ``_scan_and_build_em_data``.
    index : HulkIndex
        Reference index (provides transcript/gene coordinates).
    counter : ReadCounter
        Has gdna_exonic_init (per-gene) for aggregating locus gDNA init.
    strand_models : StrandModels
        For strand specificity check.

    Returns
    -------
    list[Locus]
    """
    nt = index.num_transcripts
    nrna_base = em_data.nrna_base_index
    offsets = em_data.offsets
    t_indices = em_data.t_indices
    t_to_g = index.t_to_g_arr

    uf = _UnionFind(nt)

    # Union all mRNA transcript indices that co-occur in any EM unit.
    # A unit's candidates may include mRNA, nRNA, and gDNA shadows;
    # we extract only mRNA indices (< nrna_base) for connectivity.
    unit_to_tset: list[list[int]] = []
    for u in range(em_data.n_units):
        s, e = int(offsets[u]), int(offsets[u + 1])
        t_seg = t_indices[s:e]
        mrna_inds = t_seg[t_seg < nrna_base]
        unique_ts = np.unique(mrna_inds).tolist()
        unit_to_tset.append(unique_ts)
        if len(unique_ts) > 1:
            first = unique_ts[0]
            for t in unique_ts[1:]:
                uf.union(first, t)

    # Extract connected components
    component_map: dict[int, list[int]] = {}
    # Only transcripts that appear in EM units need loci
    active_transcripts: set[int] = set()
    for ts in unit_to_tset:
        active_transcripts.update(ts)
    for t in active_transcripts:
        root = uf.find(t)
        component_map.setdefault(root, []).append(t)

    # Map each transcript to its component root for unit assignment
    t_to_root = np.full(nt, -1, dtype=np.int32)
    for t in active_transcripts:
        t_to_root[t] = uf.find(t)

    # Assign EM units to components
    root_to_units: dict[int, list[int]] = {r: [] for r in component_map}
    for u, ts in enumerate(unit_to_tset):
        if ts:
            root = t_to_root[ts[0]]
            root_to_units[root].append(u)

    # Build Locus objects
    t_refs = index.t_df["ref"].values
    t_starts = index.t_df["start"].values
    t_ends = index.t_df["end"].values

    loci = []
    for lid, (root, t_list) in enumerate(sorted(component_map.items())):
        t_arr = np.array(sorted(t_list), dtype=np.int32)
        g_set = sorted(set(int(t_to_g[t]) for t in t_arr))
        g_arr = np.array(g_set, dtype=np.int32)
        u_arr = np.array(sorted(root_to_units[root]), dtype=np.int32)

        # gDNA footprint: merge transcript genomic extents
        intervals = []
        for t in t_arr:
            intervals.append((str(t_refs[t]), int(t_starts[t]), int(t_ends[t])))
        merged = _merge_intervals(intervals)
        footprint_bp = sum(e - s for _, s, e in merged)

        # gDNA init: sum of per-gene gDNA init for genes in the locus
        gdna_init = float(counter.gdna_exonic_init[g_arr].sum())

        loci.append(Locus(
            locus_id=lid,
            transcript_indices=t_arr,
            gene_indices=g_arr,
            unit_indices=u_arr,
            gdna_intervals=merged,
            gdna_footprint_bp=footprint_bp,
            gdna_init_count=gdna_init,
        ))

    return loci


def _build_locus_em_data(
    locus,
    em_data,
    counter,
    index: HulkIndex,
    mean_frag: float,
) -> 'LocusEMData':
    """Extract and renumber global EMData into a per-locus sub-problem.

    Component layout per locus::

        [0, n_t)           — mRNA (one per local transcript)
        [n_t, 2*n_t)       — nRNA (one per local transcript)
        [2*n_t, 2*n_t+n_g) — gDNA (one per gene in the locus)

    Parameters
    ----------
    locus : Locus
    em_data : EMData
    counter : ReadCounter
    index : HulkIndex
    mean_frag : float

    Returns
    -------
    LocusEMData
    """
    t_arr = locus.transcript_indices
    g_arr = locus.gene_indices
    n_t = len(t_arr)
    n_g = len(g_arr)
    n_components = 2 * n_t + n_g

    nrna_base = em_data.nrna_base_index
    gdna_base = em_data.gdna_exonic_base_index

    # Build global → local component map
    global_to_local = {}
    for local_i, global_t in enumerate(t_arr):
        global_to_local[int(global_t)] = local_i             # mRNA
        global_to_local[nrna_base + int(global_t)] = n_t + local_i  # nRNA
    # Per-gene gDNA shadows: [2*n_t, 2*n_t + n_g)
    gdna_local_base = 2 * n_t
    for local_g, global_g in enumerate(g_arr):
        global_to_local[gdna_base + int(global_g)] = gdna_local_base + local_g

    # Slice and renumber CSR
    global_offsets = em_data.offsets
    global_t_indices = em_data.t_indices
    global_log_liks = em_data.log_liks
    global_count_cols = em_data.count_cols

    local_offsets = [0]
    local_t_indices = []
    local_log_liks = []
    local_count_cols = []
    local_locus_t = []
    local_locus_ct = []

    for u in locus.unit_indices:
        s, e = int(global_offsets[u]), int(global_offsets[u + 1])
        # Collect candidates, deduplicating by local component index.
        # Multiple global entries can map to the same local component
        # (e.g. duplicate nRNA from multimapper hits); keep best log_lik.
        best_per_local: dict[int, tuple[float, int]] = {}
        for j in range(s, e):
            gidx = int(global_t_indices[j])
            lidx = global_to_local.get(gidx, -1)
            if lidx < 0:
                continue  # skip candidates not in this locus
            ll = float(global_log_liks[j])
            cc = int(global_count_cols[j])
            prev = best_per_local.get(lidx)
            if prev is None or ll > prev[0]:
                best_per_local[lidx] = (ll, cc)
        for lidx, (ll, cc) in best_per_local.items():
            local_t_indices.append(lidx)
            local_log_liks.append(ll)
            local_count_cols.append(cc)
        local_offsets.append(len(local_t_indices))
        local_locus_t.append(int(em_data.locus_t_indices[u]))
        local_locus_ct.append(int(em_data.locus_count_cols[u]))

    # Build local init vectors
    unique_totals = np.zeros(n_components, dtype=np.float64)
    unique_totals[:n_t] = counter.unique_counts[t_arr].sum(axis=1)
    unique_totals[n_t:2*n_t] = counter.nrna_init[t_arr]
    # Per-gene gDNA init
    unique_totals[gdna_local_base:gdna_local_base + n_g] = (
        counter.gdna_exonic_init[g_arr]
    )

    # Build effective lengths
    eff_len = np.ones(n_components, dtype=np.float64)
    eff_len[:n_t] = counter.effective_lengths[t_arr]

    # nRNA: per-transcript unspliced span
    if counter._transcript_spans is not None:
        nrna_eff = np.maximum(
            counter._transcript_spans[t_arr] - mean_frag + 1.0, 1.0
        )
        eff_len[n_t:2*n_t] = nrna_eff

    # gDNA: per-gene span (matches global EM eff_len computation)
    if counter._gene_spans is not None:
        gene_eff = np.maximum(
            counter._gene_spans[g_arr] - mean_frag + 1.0, 1.0
        )
        eff_len[gdna_local_base:gdna_local_base + n_g] = gene_eff

    # Build prior
    prior = np.full(n_components, counter.em_prior, dtype=np.float64)
    # Zero gDNA prior per-gene when that gene's init is zero
    for local_g, global_g in enumerate(g_arr):
        if counter.gdna_exonic_init[int(global_g)] == 0.0:
            prior[gdna_local_base + local_g] = 0.0
    # Zero nRNA prior for single-exon transcripts
    if counter._transcript_spans is not None:
        for local_i, global_t in enumerate(t_arr):
            t_exon_approx = counter._t_eff_len[global_t] + mean_frag - 1.0
            if counter._transcript_spans[global_t] <= t_exon_approx:
                prior[n_t + local_i] = 0.0

    return LocusEMData(
        locus=locus,
        offsets=np.array(local_offsets, dtype=np.int64),
        t_indices=np.array(local_t_indices, dtype=np.int32),
        log_liks=np.array(local_log_liks, dtype=np.float64),
        count_cols=np.array(local_count_cols, dtype=np.uint8),
        locus_t_indices=np.array(local_locus_t, dtype=np.int32),
        locus_count_cols=np.array(local_locus_ct, dtype=np.uint8),
        n_transcripts=n_t,
        n_genes=n_g,
        n_components=n_components,
        local_to_global_t=t_arr.copy(),
        local_to_global_g=g_arr.copy(),
        unique_totals=unique_totals,
        nrna_init=counter.nrna_init[t_arr].copy(),
        gdna_init=counter.gdna_exonic_init[g_arr].copy(),
        effective_lengths=eff_len,
        prior=prior,
        gdna_intervals=locus.gdna_intervals,
    )


# ---------------------------------------------------------------------------
# Simple per-gene gDNA initialization
# ---------------------------------------------------------------------------


def _compute_gdna_init(
    gene_sense_all: np.ndarray,
    gene_antisense_all: np.ndarray,
    strand_models: StrandModels,
) -> np.ndarray:
    """Compute strand-corrected per-gene gDNA initialization.

    Uses unspliced sense/antisense fragment counts per gene,
    solved exactly from the linear mixing model.

    Model::

        S_g = G_g/2 + R_g × SS      (sense)
        A_g = G_g/2 + R_g × (1-SS)  (antisense)

    where G_g = gDNA fragments, R_g = RNA fragments, SS = strand
    specificity.  gDNA is 50/50 sense/antisense (unstranded);
    RNA is classified sense with probability SS.

    Exact solution::

        G_g = 2 × (A_g × SS - S_g × (1-SS)) / (2SS - 1)

    At SS=1.0: G_g = 2 × A_g (all antisense is gDNA).
    At SS→0.5: denominator→0, estimation impossible (physics limit).

    When 2SS - 1 ≤ 0.2 (SS ≤ 0.6), strand information is too
    weak to separate gDNA from RNA; returns zeros.

    Parameters
    ----------
    gene_sense_all : np.ndarray
        float64[num_genes] — unspliced sense fragment counts per gene.
    gene_antisense_all : np.ndarray
        float64[num_genes] — unspliced antisense fragment counts per gene.
    strand_models : StrandModels
        Trained strand models (exonic_spliced provides SS).

    Returns
    -------
    np.ndarray
        float64[num_genes] gDNA initialization per gene.
    """
    ss = strand_models.exonic_spliced.strand_specificity
    denom = 2.0 * ss - 1.0

    if denom <= 0.2:
        # SS ≤ 0.6 — strand info too noisy for reliable estimation
        return np.zeros_like(gene_sense_all)

    numerator = gene_antisense_all * ss - gene_sense_all * (1.0 - ss)
    return np.maximum(0.0, 2.0 * numerator / denom)


def _compute_nrna_init(
    transcript_intronic_sense: np.ndarray,
    transcript_intronic_antisense: np.ndarray,
    transcript_spans: np.ndarray,
    effective_lengths: np.ndarray,
    mean_frag: float,
    strand_models: StrandModels,
) -> np.ndarray:
    """Compute per-transcript nRNA initialization from intronic evidence.

    nRNA is a transcript-level phenomenon: each transcript isoform
    produces its own pre-mRNA with its own intron structure.

    Model::

        sense_int   = gDNA_int/2 + nRNA_int × SS
        anti_int    = gDNA_int/2 + nRNA_int × (1-SS)

    gDNA is 50/50 in introns (cancels in subtraction); nRNA is
    classified sense with probability SS.

    Exact solution::

        nRNA_int = (sense_int - anti_int) / (2SS - 1)

    At SS=1.0: nRNA_int = sense − anti (all antisense is gDNA).
    At SS→0.5: denominator→0, sense ≈ anti, estimation impossible.

    When 2SS − 1 ≤ 0.2 (SS ≤ 0.6), strand information is too
    weak; returns zeros.

    Single-exon transcripts (no introns) get nrna_init = 0 because
    nRNA is physically identical to mRNA without introns.

    Parameters
    ----------
    transcript_intronic_sense : np.ndarray
        float64[num_transcripts] — intronic sense counts per transcript.
    transcript_intronic_antisense : np.ndarray
        float64[num_transcripts] — intronic antisense counts per transcript.
    transcript_spans : np.ndarray
        float64[num_transcripts] — genomic span per transcript.
    effective_lengths : np.ndarray
        float64[num_transcripts] — exonic effective length per transcript.
    mean_frag : float
        Mean fragment length.
    strand_models : StrandModels
        Trained strand models (exonic_spliced provides SS).

    Returns
    -------
    np.ndarray
        float64[num_transcripts] nRNA initialization per transcript.
    """
    ss = strand_models.exonic_spliced.strand_specificity
    denom = 2.0 * ss - 1.0

    if denom <= 0.2:
        # SS ≤ 0.6 — strand info too noisy for reliable estimation
        nrna_init = np.zeros_like(transcript_intronic_sense)
    else:
        raw = (transcript_intronic_sense - transcript_intronic_antisense) / denom
        nrna_init = np.maximum(0.0, raw)

    # Zero for single-exon transcripts (no introns → no intronic evidence)
    exonic_approx = effective_lengths + mean_frag - 1.0
    intronic_span = np.maximum(transcript_spans - exonic_approx, 0.0)
    nrna_init[intronic_span <= 0] = 0.0

    return nrna_init


# ---------------------------------------------------------------------------
# Count from buffer (unified EM)
# ---------------------------------------------------------------------------


def count_from_buffer(
    buffer: FragmentBuffer,
    index: HulkIndex,
    strand_models: StrandModels,
    insert_models: InsertSizeModels,
    stats: PipelineStats,
    *,
    seed: int | None = None,
    em_pseudocount: float = 0.5,
    em_iterations: int = 1000,
    log_every: int = 1_000_000,
    gdna_splice_penalties: dict | None = None,
    gdna_threshold: float = 0.5,
    confidence_threshold: float = 0.95,
    overlap_exponents: dict | None = None,
) -> ReadCounter:
    """Assign counts from buffered fragments via three-pool EM.

    Unique fragments contribute discrete counts, while ambiguous
    fragments contribute posterior-expected counts.

    1. **SPLICED_ANNOT + unique**: deterministic mRNA assignment.
    2. **All other**: enter the EM with mRNA + nRNA + gDNA candidates.
    3. **gDNA initialization**: ``2 × n_antisense`` per gene.
       nRNA initialized to zero (EM discovers allocation).

    Parameters
    ----------
    buffer : FragmentBuffer
        Finalized buffer from :func:`scan_and_buffer`.
    index : HulkIndex
        The loaded reference index.
    strand_models : StrandModels
        Trained strand models (exonic_spliced, intergenic).
    insert_models : InsertSizeModels
        Trained insert size models.
    stats : PipelineStats
        Stats object (updated in-place with counting stats).
    seed : int or None
        Random seed for reproducibility.
    em_pseudocount : float
        Dirichlet prior pseudocount (default 0.5).
    em_iterations : int
        Maximum number of EM iterations (default 1000).
    log_every : int
        Log progress every *log_every* fragments.
    gdna_splice_penalties : dict or None
        Override default gDNA splice penalties per SpliceType.
    gdna_threshold : float
        Minimum sum of RNA posteriors to classify as RNA (default 0.5).
    confidence_threshold : float
        Minimum RNA-normalized posterior for high-confidence (default 0.95).

    Returns
    -------
    ReadCounter
    """
    # --- Compute geometry for three-pool EM ---

    # Per-transcript effective lengths: Σ(exon_lengths) - f̄ + 1
    exonic_lengths = index.t_df["length"].values.astype(np.float64)
    mean_frag = (
        insert_models.global_model.mean
        if insert_models.global_model.n_observations > 0
        else 200.0
    )
    effective_lengths = np.maximum(exonic_lengths - mean_frag + 1.0, 1.0)

    # Per-gene genomic spans (for gDNA effective lengths)
    gene_spans = (
        index.g_df["end"].values - index.g_df["start"].values
    ).astype(np.float64)

    # Per-transcript genomic spans (for nRNA effective lengths)
    transcript_spans = (
        index.t_df["end"].values - index.t_df["start"].values
    ).astype(np.float64)

    # Per-gene intronic spans (for single-exon gene detection)
    intronic_spans = index.intron_span_per_gene()

    counter = ReadCounter(
        index.num_transcripts, index.num_genes,
        seed=seed, alpha=em_pseudocount,
        effective_lengths=effective_lengths,
        t_to_g=index.t_to_g_arr,
        gene_spans=gene_spans,
        mean_frag=mean_frag,
        intronic_spans=intronic_spans,
        transcript_spans=transcript_spans,
    )

    logger.info(
        f"[START] Counting {buffer.total_fragments:,} buffered fragments "
        f"(three-pool EM: mRNA/nRNA/gDNA, {index.num_genes} genes)"
    )

    enable_gdna_shadows = gdna_threshold > 0.0
    if not enable_gdna_shadows:
        logger.info(
            "[MODE] gDNA EM competition disabled (gdna_threshold <= 0); "
            "counting ambiguous fragments as RNA-only"
        )

    # Single buffer pass: assign uniques + build EM data
    em_data = _scan_and_build_em_data(
        buffer, index, strand_models, insert_models,
        counter, stats, log_every,
        gdna_splice_penalties=gdna_splice_penalties,
        enable_gdna_shadows=enable_gdna_shadows,
        overlap_exponents=overlap_exponents,
    )

    # Strand-corrected per-gene gDNA initialization from antisense
    if enable_gdna_shadows:
        gdna_exonic_init = _compute_gdna_init(
            counter.gene_sense_all,
            counter.gene_antisense_all,
            strand_models,
        )
    else:
        gdna_exonic_init = np.zeros(index.num_genes, dtype=np.float64)

    # Per-transcript nRNA init from intronic sense excess
    nrna_init = _compute_nrna_init(
        counter.transcript_intronic_sense,
        counter.transcript_intronic_antisense,
        transcript_spans,
        effective_lengths,
        mean_frag,
        strand_models,
    )

    counter.nrna_init = nrna_init
    counter.gdna_exonic_init = gdna_exonic_init
    counter.gdna_intronic_init = np.zeros(index.num_genes, dtype=np.float64)

    ss = strand_models.exonic_spliced.strand_specificity
    if ss <= 0.6:
        logger.warning(
            f"[WARN] Strand specificity {ss:.3f} ≤ 0.6: "
            "strand-based gDNA/nRNA estimation disabled"
        )

    logger.info(
        f"[DONE] Scan: {stats.n_counted_truly_unique:,} unique, "
        f"{em_data.n_units:,} ambiguous units "
        f"({em_data.n_candidates:,} candidates), "
        f"gdna_init={gdna_exonic_init.sum():.1f}"
    )

    # EM iteration + posterior expected-count assignment
    if em_data.n_units > 0:
        # Use locus-based EM when strand info is reliable enough for
        # per-locus gDNA discovery.  When SS ≤ 0.6, the strand model
        # is too noisy for reliable gDNA initialization; the global EM
        # handles this case better because cross-locus signal allows
        # gDNA shadow competition to function correctly.
        use_locus_em = ss > 0.6

        if use_locus_em:
            # Build loci via fragment connectivity (union-find)
            loci = _build_loci(em_data, index, counter, strand_models)

            if loci:
                max_locus_t = max(len(l.transcript_indices) for l in loci)
                max_locus_u = max(len(l.unit_indices) for l in loci)
            else:
                max_locus_t = max_locus_u = 0

            logger.info(
                f"[LOCI] {len(loci)} loci from {em_data.n_units:,} units "
                f"(largest: {max_locus_t} transcripts, {max_locus_u} units)"
            )

            # Per-locus EM + posterior assignment
            total_gdna_em = 0.0
            for locus in loci:
                if len(locus.unit_indices) == 0:
                    continue
                locus_em = _build_locus_em_data(
                    locus, em_data, counter, index, mean_frag,
                )
                theta, alpha = counter.run_locus_em(
                    locus_em, em_iterations=em_iterations,
                )
                gdna_assigned = counter.assign_locus_ambiguous(
                    locus_em, theta,
                    gdna_threshold=gdna_threshold,
                    confidence_threshold=confidence_threshold,
                )
                total_gdna_em += gdna_assigned

                if len(locus.transcript_indices) > 100:
                    logger.debug(
                        f"  Locus {locus.locus_id}: "
                        f"{len(locus.transcript_indices)} transcripts, "
                        f"{len(locus.unit_indices)} units, "
                        f"gDNA={gdna_assigned:.0f}"
                    )

            # gDNA EM counts are accumulated per-gene in
            # assign_locus_ambiguous.  Track total for stats.
            counter._locus_gdna_em_total = total_gdna_em

            logger.info(
                f"[DONE] Per-locus EM: {len(loci)} loci, "
                f"{em_data.n_units:,} ambiguous fragments, "
                f"gDNA EM={total_gdna_em:.0f}"
            )

            # Set converged theta for output methods that read it.
            counter.run_em(em_data, em_iterations=0)
        else:
            # Global EM fallback — strand info too weak for locus isolation.
            logger.info(
                "[EM] Using global EM (strand specificity too low "
                "for per-locus decomposition)"
            )
            counter.run_em(em_data, em_iterations=em_iterations)
            counter.assign_ambiguous(
                em_data,
                gdna_threshold=gdna_threshold,
                confidence_threshold=confidence_threshold,
            )
    else:
        logger.info("[SKIP] No ambiguous fragments for EM")
        counter.run_em(em_data, em_iterations=0)

    # --- Update stats with gDNA results ---
    stats.n_gdna_em = int(counter.gdna_em_count)

    logger.info(
        f"[gDNA] total={counter.gdna_total:.0f} "
        f"(intergenic={counter.gdna_unique_count:.0f}, "
        f"EM={counter.gdna_em_count:.0f}), "
        f"contamination rate={counter.gdna_contamination_rate:.2%}"
    )

    return counter


# ---------------------------------------------------------------------------
# Full pipeline orchestration
# ---------------------------------------------------------------------------

def run_pipeline(
    bam_path,
    index: HulkIndex,
    *,
    skip_duplicates: bool = True,
    include_multimap: bool = False,
    insert_size_max: int = 1000,
    log_every: int = 1_000_000,
    chunk_size: int = 1_000_000,
    max_memory_bytes: int = 2 * 1024**3,
    spill_dir: Path | str | None = None,
    sj_strand_tag: str | tuple[str, ...] = "auto",
    seed: int | None = None,
    em_pseudocount: float = 0.5,
    em_iterations: int = 1000,
    gdna_splice_penalty_unannot: float = _DEFAULT_GDNA_SPLICE_PENALTY_UNANNOT,
    gdna_threshold: float = 0.5,
    confidence_threshold: float = 0.95,
    overlap_min_frac: float = 0.99,
    overlap_exponents: dict | None = None,
) -> PipelineResult:
    """Run the complete counting pipeline with EM and gDNA modeling.

    Opens the BAM **once**, scans all fragments, trains models,
    buffers resolved fragments, then counts via EM-based assignment.
    The EM includes a genomic DNA pseudo-component that competes
    with transcripts for non-SPLICED_ANNOT fragments.

    Parameters
    ----------
    bam_path : str or Path
        Path to the name-sorted / collated BAM file.
    index : HulkIndex
        The loaded reference index.
    skip_duplicates : bool
        Discard reads marked as duplicates (default True).
    include_multimap : bool
        Include multimapping reads (default False).
    insert_size_max : int
        Maximum insert size for histogram models.
    log_every : int
        Log progress every *log_every* read-name groups.
    chunk_size : int
        Fragments per buffer chunk (default 1M).
    max_memory_bytes : int
        Max memory for in-memory buffer chunks before disk spill
        (default 2 GiB).  Set to 0 to disable spilling.
    spill_dir : Path, str, or None
        Directory for disk-spilled buffer chunks
        (default: system temp dir).
    sj_strand_tag : str, tuple of str, or ``"auto"``
        BAM tag(s) for splice-junction strand.  ``"auto"``
        (default) scans the BAM for spliced reads and detects
        which tag is present.  Pass ``"XS"`` for STAR,
        ``"ts"`` for minimap2, or a tuple like
        ``("XS", "ts")`` to check multiple tags in order.
    seed : int or None
        Random seed for reproducibility (default None).
    em_pseudocount : float
        Dirichlet prior pseudocount (default 0.5).  Applied
        uniformly to all components (transcripts and gDNA shadows).
    em_iterations : int
        Maximum number of EM iterations (default 1000).
    gdna_splice_penalty_unannot : float
        gDNA splice penalty for SPLICED_UNANNOT fragments (default 0.01).
        Higher values make gDNA more competitive for unannotated
        spliced fragments (treating them more like alignment artifacts).
    gdna_threshold : float
        Minimum sum of RNA posteriors to classify a unit as RNA
        (default 0.5).  0.0 = never assign to gDNA; 1.0 = only
        shadow-free units are RNA.
    confidence_threshold : float
        Minimum RNA-normalized posterior for an EM assignment
        to be counted as high-confidence (default 0.95).

    Returns
    -------
    PipelineResult
    """
    import pysam

    bam_path = str(bam_path)
    if spill_dir is not None:
        spill_dir = Path(spill_dir)

    # -- Resolve sj_strand_tag --
    if sj_strand_tag == "auto":
        detected = detect_sj_strand_tag(bam_path)
        if len(detected) == 1:
            sj_strand_tag = detected[0]
        elif len(detected) > 1:
            sj_strand_tag = detected
        else:
            # No tags found — all SJs will get Strand.NONE
            sj_strand_tag = ()

    # -- Single BAM pass: scan + train + buffer --
    bamfh = pysam.AlignmentFile(bam_path, "rb")
    try:
        stats, strand_models, insert_models, buffer = (
            scan_and_buffer(
                bamfh.fetch(until_eof=True),
                index,
                skip_duplicates=skip_duplicates,
                include_multimap=include_multimap,
                log_every=log_every,
                insert_size_max=insert_size_max,
                chunk_size=chunk_size,
                max_memory_bytes=max_memory_bytes,
                spill_dir=spill_dir,
                sj_strand_tag=sj_strand_tag,
                overlap_min_frac=overlap_min_frac,
            )
        )
    finally:
        bamfh.close()

    # -- Count assignment via unified EM --
    # Build gDNA splice penalty dict from the user-facing parameter
    gdna_splice_penalties = dict(_GDNA_SPLICE_PENALTIES)
    gdna_splice_penalties[SpliceType.SPLICED_UNANNOT] = (
        gdna_splice_penalty_unannot
    )

    try:
        counter = count_from_buffer(
            buffer,
            index,
            strand_models,
            insert_models,
            stats,
            seed=seed,
            em_pseudocount=em_pseudocount,
            em_iterations=em_iterations,
            log_every=log_every,
            gdna_splice_penalties=gdna_splice_penalties,
            gdna_threshold=gdna_threshold,
            confidence_threshold=confidence_threshold,
            overlap_exponents=overlap_exponents,
        )
    finally:
        buffer.cleanup()

    return PipelineResult(
        stats=stats,
        strand_models=strand_models,
        insert_models=insert_models,
        counter=counter,
    )
